<Window x:Class="VELO.UI.Dialogs.DownloadsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Descargas — VELO"
        Width="620" Height="520"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundDarkBrush}"
        Foreground="{StaticResource TextPrimaryBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock x:Name="HeaderLabel" Grid.Row="0" FontSize="20" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

        <!-- List -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="DownloadList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource BackgroundMidBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Margin="0,0,0,6" Padding="14,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Row 0: filename + action buttons -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <!-- Icon depending on state -->
                                        <TextBlock FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="⬇"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding State}" Value="Completed">
                                                            <Setter Property="Text" Value="✓"/>
                                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding State}" Value="Cancelled">
                                                            <Setter Property="Text" Value="✕"/>
                                                            <Setter Property="Foreground" Value="#FF3D71"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding State}" Value="Interrupted">
                                                            <Setter Property="Text" Value="⚠"/>
                                                            <Setter Property="Foreground" Value="#FFB300"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding FileName}"
                                                   FontSize="13" FontWeight="Medium"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Buttons -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <!-- Open/run file button — shown when completed -->
                                        <Button Content="▶" FontSize="11" Padding="6"
                                                ToolTip="Abrir / ejecutar archivo"
                                                Click="OpenFile_Click"
                                                Tag="{Binding FilePath}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding State}" Value="Completed">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <!-- Open folder button — shown when completed -->
                                        <Button Content="📂" FontSize="13" Padding="6"
                                                ToolTip="Abrir carpeta"
                                                Click="OpenFolder_Click"
                                                Tag="{Binding FilePath}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding State}" Value="Completed">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <!-- Remove button — shown when not in progress -->
                                        <Button Content="✕" FontSize="10" Padding="6"
                                                ToolTip="Quitar de la lista"
                                                Click="Remove_Click"
                                                Tag="{Binding Id}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsInProgress}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <!-- Row 1: progress bar — only while in progress -->
                                <ProgressBar Grid.Row="1"
                                             Value="{Binding Progress, Mode=OneWay}"
                                             Maximum="100"
                                             Height="4"
                                             Margin="0,8,0,4"
                                             Background="{StaticResource BackgroundDarkBrush}"
                                             Foreground="#00E5FF"
                                             BorderThickness="0">
                                    <ProgressBar.Style>
                                        <Style TargetType="ProgressBar">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsInProgress}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ProgressBar.Style>
                                </ProgressBar>

                                <!-- Row 2: status text -->
                                <TextBlock Grid.Row="2"
                                           Text="{Binding StatusText}"
                                           FontSize="11"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="CountLabel"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="12" VerticalAlignment="Center"/>
            <Button x:Name="ClearBtn" Grid.Column="1"
                    Style="{StaticResource IconButton}"
                    Padding="12,6" FontSize="12"
                    Click="ClearCompleted_Click"/>
        </Grid>
    </Grid>
</Window>
