<Window x:Class="VELO.UI.Dialogs.AIResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VELO IA"
        Width="580" Height="500"
        MinWidth="420" MinHeight="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource BackgroundDarkestBrush}"
        Foreground="{StaticResource TextPrimaryBrush}">

    <!-- Phase 5.2 re-skin — IA result dialog. -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header chip -->
            <RowDefinition Height="*"/>      <!-- Result body -->
            <RowDefinition Height="Auto"/>   <!-- Action bar -->
        </Grid.RowDefinitions>

        <!-- ── Header / adapter chip ─────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceDarkBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="ActionLabel" Grid.Column="0"
                           Text="Resultado IA"
                           FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <!-- AdapterChip — defaults to green (local); code-behind repaints
                     when Claude/Ollama remote etc. is active. -->
                <Border x:Name="AdapterChip" Grid.Column="1"
                        Background="#FF1A3A20"
                        BorderBrush="#FF2EB54F"
                        BorderThickness="1"
                        CornerRadius="99"
                        Padding="10,3"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="AdapterChipText"
                               Text="🖥 Local"
                               FontSize="10.5"
                               FontWeight="SemiBold"
                               Foreground="#FF2EB54F"/>
                </Border>
                <Button x:Name="CloseButton" Grid.Column="3"
                        Style="{StaticResource IconButton}"
                        Content="✕" FontSize="12"
                        Padding="8,4"
                        Click="Close_Click"/>
            </Grid>
        </Border>

        <!-- ── Result body ───────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="18,14">
            <StackPanel>
                <TextBlock x:Name="SourceLabel"
                           FontSize="10"
                           Foreground="{StaticResource TextMutedBrush}"
                           Margin="0,0,0,4"
                           Text=""/>
                <TextBlock x:Name="SourceText"
                           FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,14"
                           FontStyle="Italic"
                           Visibility="Collapsed"/>
                <!-- Loading skeleton card -->
                <Border x:Name="LoadingPanel"
                        HorizontalAlignment="Left"
                        Background="{StaticResource SurfaceMidBrush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}"
                        BorderThickness="1"
                        Padding="14,9"
                        CornerRadius="10"
                        Visibility="Visible">
                    <TextBlock Text="⏳ Generando…"
                               FontSize="11.5"
                               Foreground="{StaticResource AccentPurpleLightBrush}"/>
                </Border>
                <TextBlock x:Name="ResultText"
                           FontSize="13.5"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           TextWrapping="Wrap"
                           LineHeight="20"
                           Visibility="Collapsed"/>
            </StackPanel>
        </ScrollViewer>

        <!-- ── Action bar ────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{StaticResource SurfaceDarkBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,1,0,0"
                Padding="18,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CopyButton"
                        Style="{StaticResource GhostButton}"
                        Content="📋 Copiar"
                        FontSize="11.5"
                        Padding="14,7"
                        Margin="0,0,8,0"
                        Click="Copy_Click"/>
                <Button x:Name="FollowUpButton"
                        Style="{StaticResource GhostButton}"
                        Content="💬 Preguntar seguimiento"
                        FontSize="11.5"
                        Padding="14,7"
                        Margin="0,0,8,0"
                        Click="FollowUp_Click"/>
                <Button x:Name="RegenerateButton"
                        Style="{StaticResource PrimaryButton}"
                        Content="🔄 Regenerar"
                        FontSize="11.5"
                        Padding="16,7"
                        Click="Regenerate_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
