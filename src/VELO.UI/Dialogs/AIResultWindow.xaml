<Window x:Class="VELO.UI.Dialogs.AIResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VELO IA"
        Width="540" Height="480"
        MinWidth="400" MinHeight="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#FF0D0D0D"
        Foreground="#FFE0E0E8">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header chip -->
            <RowDefinition Height="*"/>      <!-- Result body -->
            <RowDefinition Height="Auto"/>   <!-- Action bar -->
        </Grid.RowDefinitions>

        <!-- ── Header / adapter chip ─────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="#FF111118"
                BorderBrush="#FF2A2A3A"
                BorderThickness="0,0,0,1"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="ActionLabel" Grid.Column="0"
                           Text="Resultado IA"
                           FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="#FFE0E0E8"/>
                <Border x:Name="AdapterChip" Grid.Column="1"
                        Background="#FF1A3A20"
                        BorderBrush="#FF2EB54F"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="8,2"
                        Margin="10,0,0,0"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="AdapterChipText"
                               Text="🖥 Local"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="#FF2EB54F"/>
                </Border>
                <Button x:Name="CloseButton" Grid.Column="3"
                        Content="✕" FontSize="11"
                        Background="Transparent"
                        Foreground="#FF8080A0"
                        BorderThickness="0"
                        Padding="8,3"
                        Cursor="Hand"
                        Click="Close_Click"/>
            </Grid>
        </Border>

        <!-- ── Result body ───────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="14,10">
            <StackPanel>
                <TextBlock x:Name="SourceLabel"
                           FontSize="10"
                           Foreground="#FF606080"
                           Margin="0,0,0,4"
                           Text=""/>
                <TextBlock x:Name="SourceText"
                           FontSize="11"
                           Foreground="#FF707088"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"
                           FontStyle="Italic"
                           Visibility="Collapsed"/>
                <Border x:Name="LoadingPanel"
                        HorizontalAlignment="Left"
                        Background="#FF14141F"
                        Padding="10,6"
                        CornerRadius="4"
                        Visibility="Visible">
                    <TextBlock Text="⏳ Generando…"
                               FontSize="11"
                               Foreground="#FF8080A0"/>
                </Border>
                <TextBlock x:Name="ResultText"
                           FontSize="13"
                           Foreground="#FFE0E0E8"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"/>
            </StackPanel>
        </ScrollViewer>

        <!-- ── Action bar ────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="#FF111118"
                BorderBrush="#FF2A2A3A"
                BorderThickness="0,1,0,0"
                Padding="14,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CopyButton"
                        Content="📋 Copiar"
                        FontSize="11"
                        Padding="10,5"
                        Margin="0,0,6,0"
                        Click="Copy_Click"/>
                <Button x:Name="FollowUpButton"
                        Content="💬 Preguntar seguimiento"
                        FontSize="11"
                        Padding="10,5"
                        Margin="0,0,6,0"
                        Click="FollowUp_Click"/>
                <Button x:Name="RegenerateButton"
                        Content="🔄 Regenerar"
                        FontSize="11"
                        Padding="10,5"
                        Click="Regenerate_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
