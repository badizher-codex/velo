<Window x:Class="VELO.UI.Dialogs.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="History — VELO"
        Width="760" Height="640"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundDarkestBrush}"
        Foreground="{StaticResource TextPrimaryBrush}">

    <!-- Phase 5.1 re-skin — frame 4. Same data, new look. -->
    <DockPanel Margin="20">

        <!-- Header row -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" x:Name="HeaderLabel"
                       Text="History"
                       FontSize="24" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       VerticalAlignment="Center"/>

            <Button Grid.Column="1" x:Name="ReloadButton"
                    Content="↻"
                    Style="{StaticResource IconButton}"
                    FontSize="15"
                    Padding="10,6"
                    Margin="0,0,8,0"
                    Click="Reload_Click"/>

            <Button Grid.Column="2" x:Name="ClearButton"
                    Style="{StaticResource GhostButton}"
                    Padding="14,8"
                    FontSize="12"
                    Foreground="{StaticResource BadgeRedBrush}"
                    BorderBrush="{StaticResource BadgeRedBrush}"
                    Click="Clear_Click"/>
        </Grid>

        <!-- Search box -->
        <Border DockPanel.Dock="Top" Margin="0,0,0,14"
                Background="{StaticResource SurfaceLightBrush}"
                CornerRadius="10"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="🔍" FontSize="14"
                           Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center"
                           Margin="14,0,8,0"/>
                <TextBox x:Name="SearchBox" Grid.Column="1"
                         Background="Transparent"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         CaretBrush="{StaticResource AccentPurpleBrush}"
                         SelectionBrush="{StaticResource AccentPurpleBrush}"
                         BorderThickness="0"
                         Padding="0,11,12,11" FontSize="13"
                         TextChanged="SearchBox_TextChanged"/>
            </Grid>
        </Border>

        <!-- Footer -->
        <Grid DockPanel.Dock="Bottom" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="StatusLabel"
                       Foreground="{StaticResource TextMutedBrush}" FontSize="12"
                       VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" x:Name="DiagLabel"
                       Foreground="{StaticResource TextMutedBrush}"
                       Opacity="0.55"
                       FontSize="10"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"/>
        </Grid>

        <!--
            List — bound to ObservableCollection<HistoryEntryRowView>.
            All template bindings target plain CLR properties on the wrapper
            (text + Visibility pre-computed). No converters, no Source-static
            bindings — kept exactly as v2.4.11 designed.
        -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="HistoryList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,6" Padding="14,12"
                                Background="{StaticResource SurfaceMidBrush}"
                                BorderBrush="{StaticResource BorderSubtleBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Cursor="Hand"
                                MouseLeftButtonDown="Entry_Click"
                                Tag="{Binding Url}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left column: title, url, security badges -->
                                <StackPanel Grid.Column="0">

                                    <!-- Title row with optional 👾 -->
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="👾 " FontSize="13"
                                                   Visibility="{Binding MonsterVisibility}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="13.5" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- URL row -->
                                    <TextBlock Text="{Binding Url}"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,3,0,0"/>

                                    <!-- Security badges row -->
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">

                                        <!-- Blocked count (red) -->
                                        <Border Style="{StaticResource StatusPill}"
                                                Background="{StaticResource BadgeRedBgBrush}"
                                                Padding="8,3"
                                                Margin="0,0,6,0"
                                                Visibility="{Binding BlockedBadgeVisibility}">
                                            <TextBlock Text="{Binding BlockedBadgeText}"
                                                       FontSize="10.5" FontWeight="SemiBold"
                                                       Foreground="{StaticResource BadgeRedBrush}"/>
                                        </Border>

                                        <!-- Trackers (amber) -->
                                        <Border Style="{StaticResource StatusPill}"
                                                Background="{StaticResource BadgeAmberBgBrush}"
                                                Padding="8,3"
                                                Margin="0,0,6,0"
                                                Visibility="{Binding TrackerBadgeVisibility}">
                                            <TextBlock Text="{Binding TrackerBadgeText}"
                                                       FontSize="10.5" FontWeight="SemiBold"
                                                       Foreground="{StaticResource BadgeAmberBrush}"/>
                                        </Border>

                                        <!-- Malware (red, more emphatic) -->
                                        <Border Style="{StaticResource StatusPill}"
                                                Background="{StaticResource BadgeRedBgBrush}"
                                                BorderBrush="{StaticResource BadgeRedBrush}"
                                                BorderThickness="1"
                                                Padding="8,3"
                                                Margin="0,0,6,0"
                                                Visibility="{Binding MalwareBadgeVisibility}">
                                            <TextBlock Text="{Binding MalwareBadgeText}"
                                                       FontSize="10.5" FontWeight="SemiBold"
                                                       Foreground="{StaticResource BadgeRedBrush}"/>
                                        </Border>

                                        <!-- No threats (green) — only when all counts are zero -->
                                        <Border Style="{StaticResource StatusPill}"
                                                Background="{StaticResource BadgeGreenBgBrush}"
                                                Padding="8,3"
                                                Visibility="{Binding NoThreatsVisibility}">
                                            <TextBlock Text="{Binding NoThreatsText}"
                                                       FontSize="10.5" FontWeight="SemiBold"
                                                       Foreground="{StaticResource BadgeGreenBrush}"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Right column: time + delete -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Top"
                                            Margin="12,0,0,0">
                                    <TextBlock Text="{Binding VisitedAt, StringFormat='{}{0:dd/MM HH:mm}'}"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="11"
                                               HorizontalAlignment="Right"/>
                                    <Button Content="✕" FontSize="10"
                                            Style="{StaticResource IconButton}"
                                            Padding="6,2"
                                            HorizontalAlignment="Right"
                                            Margin="0,6,0,0"
                                            Click="Delete_Click"
                                            Tag="{Binding Id}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</Window>
