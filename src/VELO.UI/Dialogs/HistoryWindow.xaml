<Window x:Class="VELO.UI.Dialogs.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="History — VELO"
        Width="720" Height="620"
        WindowStartupLocation="CenterOwner"
        Background="#181820"
        Foreground="#E2E2E8">

    <DockPanel Margin="16">

        <!-- Header row -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" x:Name="HeaderLabel"
                       Text="History"
                       FontSize="22" FontWeight="SemiBold"
                       Foreground="#E2E2E8"
                       VerticalAlignment="Center"/>

            <Button Grid.Column="1" x:Name="ReloadButton"
                    Content="↻"
                    FontSize="14"
                    Padding="10,5"
                    Background="#2A2A36" Foreground="#E2E2E8"
                    BorderBrush="#3A3A4A" BorderThickness="1"
                    Margin="0,0,8,0"
                    Click="Reload_Click"/>

            <Button Grid.Column="2" x:Name="ClearButton"
                    Padding="10,5"
                    Background="#3A1A1A" Foreground="#FF6B6B"
                    BorderBrush="#5A2A2A" BorderThickness="1"
                    Click="Clear_Click"/>
        </Grid>

        <!-- Search box -->
        <Border DockPanel.Dock="Top" Margin="0,0,0,12"
                Background="#22222E" CornerRadius="6"
                BorderBrush="#3A3A4A" BorderThickness="1">
            <TextBox x:Name="SearchBox"
                     Background="Transparent"
                     Foreground="#E2E2E8"
                     CaretBrush="#E2E2E8"
                     BorderThickness="0"
                     Padding="10,8" FontSize="13"
                     TextChanged="SearchBox_TextChanged"/>
        </Border>

        <!-- Footer -->
        <Grid DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="StatusLabel"
                       Foreground="#888899" FontSize="12"
                       VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" x:Name="DiagLabel"
                       Foreground="#555566" FontSize="10"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"/>
        </Grid>

        <!--
            List — bound to ObservableCollection<HistoryEntryRowView>.
            All template bindings target plain CLR properties on the wrapper
            (text + Visibility pre-computed). No converters, no Source-static
            bindings. If anything goes wrong the row renders empty/literal,
            never blank-with-no-error like the previous implementation.
        -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="HistoryList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,4" Padding="12,10"
                                Background="#22222E"
                                BorderBrush="#2A2A3A"
                                BorderThickness="1"
                                CornerRadius="6"
                                Cursor="Hand"
                                MouseLeftButtonDown="Entry_Click"
                                Tag="{Binding Url}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left column: title, url, security badges -->
                                <StackPanel Grid.Column="0">

                                    <!-- Title row with optional 👾 -->
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="👾 " FontSize="13"
                                                   Visibility="{Binding MonsterVisibility}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="#E2E2E8"
                                                   FontSize="13" FontWeight="Medium"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- URL row -->
                                    <TextBlock Text="{Binding Url}"
                                               Foreground="#888899"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,2,0,0"/>

                                    <!-- Security badges row -->
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">

                                        <!-- Blocked count (red) -->
                                        <Border CornerRadius="3" Padding="5,2" Margin="0,0,4,0"
                                                Background="#33FF3D71"
                                                Visibility="{Binding BlockedBadgeVisibility}">
                                            <TextBlock Text="{Binding BlockedBadgeText}"
                                                       FontSize="10" Foreground="#FF6B96"/>
                                        </Border>

                                        <!-- Trackers (amber) -->
                                        <Border CornerRadius="3" Padding="5,2" Margin="0,0,4,0"
                                                Background="#33FFB300"
                                                Visibility="{Binding TrackerBadgeVisibility}">
                                            <TextBlock Text="{Binding TrackerBadgeText}"
                                                       FontSize="10" Foreground="#FFB94A"/>
                                        </Border>

                                        <!-- Malware (red) -->
                                        <Border CornerRadius="3" Padding="5,2" Margin="0,0,4,0"
                                                Background="#44FF0000"
                                                Visibility="{Binding MalwareBadgeVisibility}">
                                            <TextBlock Text="{Binding MalwareBadgeText}"
                                                       FontSize="10" Foreground="#FF6B6B"/>
                                        </Border>

                                        <!-- No threats (green) — only when all counts are zero -->
                                        <TextBlock Text="{Binding NoThreatsText}"
                                                   FontSize="10" Foreground="#4CAF50"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding NoThreatsVisibility}"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Right column: time + delete -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Top"
                                            Margin="12,0,0,0">
                                    <TextBlock Text="{Binding VisitedAt, StringFormat='{}{0:dd/MM HH:mm}'}"
                                               Foreground="#888899"
                                               FontSize="11"
                                               HorizontalAlignment="Right"/>
                                    <Button Content="✕" FontSize="10"
                                            Background="Transparent" Foreground="#666677"
                                            BorderThickness="0" Padding="6,2"
                                            HorizontalAlignment="Right"
                                            Margin="0,4,0,0"
                                            Cursor="Hand"
                                            Click="Delete_Click"
                                            Tag="{Binding Id}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</Window>
