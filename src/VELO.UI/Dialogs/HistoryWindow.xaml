<Window x:Class="VELO.UI.Dialogs.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="History — VELO"
        Width="720" Height="620"
        WindowStartupLocation="CenterOwner"
        Background="#181820"
        Foreground="#E2E2E8">

    <!--
        v2.4.10 — Complete rewrite. The previous HistoryWindow accumulated
        7 hotfixes (v2.4.3 through v2.4.9) that all failed to surface 368
        entries we knew were in the DB. The bug was somewhere between
        `_all = entries` and the visual tree, hidden behind a stack of:
        dual Loaded+Activated wiring, _isLoading dedupe, Dispatcher.InvokeAsync,
        ApplyLanguage stomping on _all, and a DataTemplate with 4 chained
        converters that bound to localisation keys via static Source
        bindings. This rewrite throws all of that away and uses the
        simplest WPF pattern that exists: ObservableCollection bound
        directly via ItemsSource.
    -->

    <DockPanel Margin="16">

        <!-- Header row: title + reload + status + clear -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="History"
                       FontSize="22" FontWeight="SemiBold"
                       Foreground="#E2E2E8"
                       VerticalAlignment="Center"/>

            <Button Grid.Column="1" x:Name="ReloadButton"
                    Content="↻ Reload" Padding="10,5"
                    Background="#2A2A36" Foreground="#E2E2E8"
                    BorderBrush="#3A3A4A" BorderThickness="1"
                    Margin="0,0,8,0"
                    Click="Reload_Click"/>

            <Button Grid.Column="2" x:Name="ClearButton"
                    Content="Clear all" Padding="10,5"
                    Background="#3A1A1A" Foreground="#FF6B6B"
                    BorderBrush="#5A2A2A" BorderThickness="1"
                    Click="Clear_Click"/>
        </Grid>

        <!-- Search box -->
        <Border DockPanel.Dock="Top" Margin="0,0,0,12"
                Background="#22222E" CornerRadius="6"
                BorderBrush="#3A3A4A" BorderThickness="1">
            <TextBox x:Name="SearchBox"
                     Background="Transparent"
                     Foreground="#E2E2E8"
                     CaretBrush="#E2E2E8"
                     BorderThickness="0"
                     Padding="10,8" FontSize="13"
                     TextChanged="SearchBox_TextChanged"/>
        </Border>

        <!-- Footer: count + diagnostic -->
        <Grid DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="StatusLabel"
                       Text="Loading…"
                       Foreground="#888899" FontSize="12"
                       VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" x:Name="DiagLabel"
                       Foreground="#555566" FontSize="10"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- List — ItemsSource bound to ObservableCollection in code -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="HistoryList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,4" Padding="12,10"
                                Background="#22222E"
                                BorderBrush="#2A2A3A"
                                BorderThickness="1"
                                CornerRadius="6"
                                Cursor="Hand"
                                MouseLeftButtonDown="Entry_Click"
                                Tag="{Binding Url}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Title}"
                                               Foreground="#E2E2E8"
                                               FontSize="13" FontWeight="Medium"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Url}"
                                               Foreground="#888899"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" VerticalAlignment="Top"
                                            Margin="12,0,0,0">
                                    <TextBlock Text="{Binding VisitedAt, StringFormat='{}{0:dd/MM HH:mm}'}"
                                               Foreground="#888899"
                                               FontSize="11"
                                               HorizontalAlignment="Right"/>
                                    <Button Content="✕" FontSize="10"
                                            Background="Transparent" Foreground="#666677"
                                            BorderThickness="0" Padding="6,2"
                                            HorizontalAlignment="Right"
                                            Margin="0,4,0,0"
                                            Cursor="Hand"
                                            Click="Delete_Click"
                                            Tag="{Binding Id}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</Window>
