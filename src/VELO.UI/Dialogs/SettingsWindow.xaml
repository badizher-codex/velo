<Window x:Class="VELO.UI.Dialogs.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VELO — Configuración"
        Width="720" Height="560"
        MinWidth="620" MinHeight="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Sidebar nav button -->
            <Style x:Key="NavButton" TargetType="Button">
                <Setter Property="Background"      Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground"      Value="{StaticResource TextSecondaryBrush}"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Padding"         Value="16,10"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource BackgroundHoverBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
                <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource AccentPurpleLightBrush}"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundDarkestBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Grid.RowSpan="2"
                Background="{StaticResource SurfaceDarkBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,1,0">
            <StackPanel Margin="8,16,8,8">
                <TextBlock Text="VELO" FontSize="20" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentPurpleLightBrush}"
                           Margin="16,0,0,22"/>

                <Button x:Name="NavPrivacidad" Content="🔒  Privacidad"
                        Style="{StaticResource NavButtonActive}"
                        Click="Nav_Click" Tag="Privacidad"/>
                <Button x:Name="NavDns" Content="🌐  DNS"
                        Style="{StaticResource NavButton}"
                        Click="Nav_Click" Tag="DNS" Margin="0,2"/>
                <Button x:Name="NavIA" Content="🧠  Inteligencia Artificial"
                        Style="{StaticResource NavButton}"
                        Click="Nav_Click" Tag="IA" Margin="0,2"/>
                <Button x:Name="NavBusqueda" Content="🔍  Búsqueda"
                        Style="{StaticResource NavButton}"
                        Click="Nav_Click" Tag="Busqueda" Margin="0,2"/>
                <Button x:Name="NavVault" Content="🔑  Vault"
                        Style="{StaticResource NavButton}"
                        Click="Nav_Click" Tag="Vault" Margin="0,2"/>
                <Button x:Name="NavCouncil" Content="🤝  Council"
                        Style="{StaticResource NavButton}"
                        Click="Nav_Click" Tag="Council" Margin="0,2"/>
                <Button x:Name="NavIdioma" Content="🌍  Idioma"
                        Style="{StaticResource NavButton}"
                        Click="Nav_Click" Tag="Idioma" Margin="0,2"/>
                <Button x:Name="NavGeneral" Content="⚙️  General"
                        Style="{StaticResource NavButton}"
                        Click="Nav_Click" Tag="General" Margin="0,2"/>
            </StackPanel>
        </Border>

        <!-- Content area -->
        <ScrollViewer Grid.Column="1" Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      Padding="32,24,32,16">
            <StackPanel>

                <!-- ── PRIVACIDAD ── -->
                <StackPanel x:Name="PanelPrivacidad">
                    <TextBlock x:Name="PrivacyTitle" Text="Privacidad" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"/>

                    <TextBlock x:Name="SecModeTitle" Text="Modo de seguridad" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <RadioButton x:Name="SecNormal" GroupName="SecMode" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock x:Name="SecNormalTitle" Text="Normal" FontWeight="SemiBold"/>
                            <TextBlock x:Name="SecNormalDesc" Text="Bloquea rastreadores y anuncios. Uso diario."
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="SecParanoid" GroupName="SecMode" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock x:Name="SecParanoidTitle" Text="Paranoid" FontWeight="SemiBold"/>
                            <TextBlock x:Name="SecParanoidDesc" Text="Bloqueo agresivo. Historial borrado al salir."
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="SecBunker" GroupName="SecMode" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock x:Name="SecBunkerTitle" Text="Bunker" FontWeight="SemiBold"/>
                            <TextBlock x:Name="SecBunkerDesc" Text="Máxima privacidad. Sin historial, sin cookies persistentes."
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </RadioButton>

                    <Separator Margin="0,0,0,16"/>

                    <TextBlock x:Name="FpTitle" Text="Protección de huella digital" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <RadioButton x:Name="FpAggressive" GroupName="Fingerprint" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock x:Name="FpAggressiveTitle" Text="Agresivo (Recomendado)" FontWeight="SemiBold"/>
                            <TextBlock x:Name="FpAggressiveDesc" Text="Canvas, WebGL, AudioContext, hardware spoof."
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="FpBalanced" GroupName="Fingerprint" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock x:Name="FpBalancedTitle" Text="Balanceado" FontWeight="SemiBold"/>
                            <TextBlock x:Name="FpBalancedDesc" Text="Protección básica. Menos riesgo de romper sitios."
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="FpOff" GroupName="Fingerprint" Margin="0,0,0,16">
                        <TextBlock x:Name="FpOffLabel" Text="Desactivado"/>
                    </RadioButton>

                    <Separator Margin="0,0,0,16"/>

                    <TextBlock x:Name="WrtcTitle" Text="WebRTC" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <RadioButton x:Name="WrtcRelay" GroupName="WebRTC" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock x:Name="WrtcRelayTitle" Text="Solo relay (Recomendado)" FontWeight="SemiBold"/>
                            <TextBlock x:Name="WrtcRelayDesc" Text="Oculta tu IP real usando solo servidores TURN."
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="WrtcDisabled" GroupName="WebRTC" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock x:Name="WrtcDisabledTitle" Text="Desactivado" FontWeight="SemiBold"/>
                            <TextBlock x:Name="WrtcDisabledDesc" Text="Elimina RTCPeerConnection. Puede romper videollamadas."
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="WrtcOff" GroupName="WebRTC" Margin="0,0,0,16">
                        <TextBlock x:Name="WrtcOffLabel" Text="Sin protección"/>
                    </RadioButton>

                    <Separator Margin="0,0,0,16"/>

                    <CheckBox x:Name="HistoryCheck" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock x:Name="HistorySaveTitle" Text="Guardar historial de navegación" FontWeight="SemiBold"/>
                            <TextBlock x:Name="HistorySaveDesc" Text="Desactiva en modo Paranoid/Bunker automáticamente."
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </CheckBox>
                    <CheckBox x:Name="ClearOnExitCheck">
                        <StackPanel>
                            <TextBlock x:Name="HistoryClearTitle" Text="Borrar historial al salir" FontWeight="SemiBold"/>
                            <TextBlock x:Name="HistoryClearDesc" Text="Siempre activo en modo Paranoid y Bunker."
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </CheckBox>

                    <Separator Margin="0,16,0,16"/>

                    <CheckBox x:Name="AutoUpdateCheck">
                        <StackPanel>
                            <TextBlock x:Name="AutoUpdateTitle" Text="Buscar actualizaciones automáticamente" FontWeight="SemiBold"/>
                            <TextBlock x:Name="AutoUpdateDesc" Text="VELO consultará GitHub cada 24h. Desactivado por defecto — la única conexión saliente que hace VELO sin tu acción."
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </CheckBox>
                </StackPanel>

                <!-- ── DNS ── -->
                <StackPanel x:Name="PanelDns" Visibility="Collapsed">
                    <TextBlock x:Name="DnsTitle" Text="DNS Privado (DoH)" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock x:Name="DnsIntro" Text="Tu ISP puede ver qué sitios visitas con DNS normal. VELO usa DNS encriptado sobre HTTPS."
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,20"/>

                    <RadioButton x:Name="DnsQuad9" GroupName="DNS" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock x:Name="DnsQuad9Title" Text="Quad9 (Recomendado)" FontWeight="SemiBold"/>
                            <TextBlock x:Name="DnsQuad9Desc" Text="Sin logs · Bloquea malware · Con sede en Suiza"
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="DnsCloudflare" GroupName="DNS" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="Cloudflare 1.1.1.1" FontWeight="SemiBold"/>
                            <TextBlock x:Name="DnsCloudflareDesc" Text="Ultra rápido · Política de privacidad limitada a 24h"
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="DnsNextDns" GroupName="DNS" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="NextDNS" FontWeight="SemiBold"/>
                            <TextBlock x:Name="DnsNextDnsDesc" Text="Filtrado personalizable · Requiere cuenta gratuita"
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="DnsCustom" GroupName="DNS" Margin="0,0,0,4">
                        <TextBlock x:Name="DnsCustomLabel" Text="Personalizado"/>
                    </RadioButton>
                    <TextBlock x:Name="DnsUrlLabel" Text="URL DoH:" FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                               Margin="20,4,0,2"/>
                    <TextBox x:Name="DnsCustomUrl" Margin="20,0,0,0" IsEnabled="False"
                             Tag="https://dns.example.com/dns-query"/>
                </StackPanel>

                <!-- ── IA ── -->
                <StackPanel x:Name="PanelIA" Visibility="Collapsed">
                    <TextBlock x:Name="AiTitle" Text="Inteligencia Artificial" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock x:Name="AiIntro" Text="VELO analiza URLs y recursos en tiempo real para detectar amenazas."
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,20"/>

                    <RadioButton x:Name="AiOffline" GroupName="AIMode" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock x:Name="AiOfflineTitle" Text="Offline (Recomendado)" FontWeight="SemiBold"/>
                            <TextBlock x:Name="AiOfflineDesc" Text="100% local. Sin API key. Reglas heurísticas."
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="AiClaude" GroupName="AIMode" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock x:Name="AiClaudeTitle" Text="Claude (Mejor detección)" FontWeight="SemiBold"/>
                            <TextBlock x:Name="AiClaudeDesc" Text="Requiere API key de Anthropic."
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </RadioButton>
                    <TextBlock x:Name="AiApiKeyLabel" Text="API Key:" FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                               Margin="20,4,0,2"/>
                    <TextBox x:Name="ApiKeyField" Margin="20,0,0,12" IsEnabled="False"
                             Tag="sk-ant-..."/>

                    <RadioButton x:Name="AiCustom" GroupName="AIMode" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock x:Name="AiCustomTitle" Text="LLM Personalizado (Ollama)" FontWeight="SemiBold"/>
                            <TextBlock x:Name="AiCustomDesc" Text="Cualquier endpoint compatible con OpenAI API."
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </RadioButton>
                    <TextBlock x:Name="AiEndpointLabel" Text="Endpoint:" FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                               Margin="20,4,0,2"/>
                    <TextBox x:Name="CustomEndpointField" Margin="20,0,0,4" IsEnabled="False"
                             Tag="http://localhost:11434"/>
                    <TextBlock x:Name="AiModelLabel" Text="Modelo:" FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                               Margin="20,0,0,2"/>
                    <TextBox x:Name="CustomModelField" Margin="20,0,0,8" IsEnabled="False"
                             Tag="llama3"/>
                    <Button x:Name="TestOllamaButton" Content="Probar conexión"
                            Margin="20,0,0,0" HorizontalAlignment="Left" IsEnabled="False"
                            Click="OnTestOllamaClick"/>
                    <TextBlock x:Name="OllamaTestResult" Margin="20,6,0,0"
                               FontSize="11" Visibility="Collapsed" TextWrapping="Wrap"/>

                    <!-- v2.4.18 — Sprint 9B: BookmarkAI auto-tag -->
                    <Border Background="{StaticResource BorderBrush}" Height="1" Margin="0,20,0,16"/>
                    <CheckBox x:Name="BookmarkAutoTagCheck" Margin="0,0,0,4">
                        <StackPanel>
                            <TextBlock x:Name="BookmarkAutoTagTitle" Text="Auto-etiquetar marcadores con IA" FontWeight="SemiBold"/>
                            <TextBlock x:Name="BookmarkAutoTagDesc" Text="Genera 3-5 etiquetas temáticas al guardar un marcador."
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </CheckBox>

                    <!-- v2.4.25 — PhishingShield domain-age (RDAP) opt-in -->
                    <CheckBox x:Name="DomainAgeCheck" Margin="0,12,0,4">
                        <StackPanel>
                            <TextBlock x:Name="DomainAgeTitle" Text="Verificar edad del dominio (RDAP)" FontWeight="SemiBold"/>
                            <TextBlock x:Name="DomainAgeDesc"
                                       Text="Consulta IANA RDAP en páginas ya marcadas como sospechosas para detectar dominios recién registrados. Cero lookups en sites buenos."
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </CheckBox>
                </StackPanel>

                <!-- ── BÚSQUEDA ── -->
                <StackPanel x:Name="PanelBusqueda" Visibility="Collapsed">
                    <TextBlock x:Name="SearchTitle" Text="Motor de búsqueda" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"/>

                    <RadioButton x:Name="SearchDDG" GroupName="Search" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock x:Name="SearchDdgTitle" Text="DuckDuckGo (Recomendado)" FontWeight="SemiBold"/>
                            <TextBlock x:Name="SearchDdgDesc" Text="Sin rastreo · Sin perfil de usuario"
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="SearchBrave" GroupName="Search" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="Brave Search" FontWeight="SemiBold"/>
                            <TextBlock x:Name="SearchBraveDesc" Text="Índice propio · Sin Google"
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="SearchSearx" GroupName="Search" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="SearxNG" FontWeight="SemiBold"/>
                            <TextBlock x:Name="SearchSearxDesc" Text="Meta-buscador open source · Auto-hospedado"
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="SearchCustom" GroupName="Search" Margin="0,0,0,8">
                        <TextBlock x:Name="SearchCustomLabel" Text="Personalizado"/>
                    </RadioButton>
                    <TextBox x:Name="SearchCustomUrl" Margin="20,0,0,0" IsEnabled="False"/>
                    <TextBlock x:Name="SearchUrlHint" Text="Usa {query} como marcador. Ej: https://mi-searx.com/search?q={query}"
                               FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                               Margin="20,4,0,0"/>
                </StackPanel>

                <!-- ── VAULT ── -->
                <StackPanel x:Name="PanelVault" Visibility="Collapsed">
                    <TextBlock x:Name="VaultPanelTitle" Text="Password Vault" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock x:Name="VaultIntro" Text="Gestor de contraseñas encriptado con AES-256-GCM. La master password nunca se almacena."
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,20"/>

                    <TextBlock x:Name="AutoLockLabel" Text="Bloqueo automático" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ComboBox x:Name="AutoLockCombo" Width="200" HorizontalAlignment="Left">
                        <ComboBoxItem x:Name="AutoLock5"     Content="5 minutos"  Tag="5"/>
                        <ComboBoxItem x:Name="AutoLock10"    Content="10 minutos" Tag="10"/>
                        <ComboBoxItem x:Name="AutoLock15"    Content="15 minutos" Tag="15"/>
                        <ComboBoxItem x:Name="AutoLock30"    Content="30 minutos" Tag="30"/>
                        <ComboBoxItem x:Name="AutoLock60"    Content="1 hora"     Tag="60"/>
                        <ComboBoxItem x:Name="AutoLockNever" Content="Nunca"      Tag="0"/>
                    </ComboBox>

                    <Separator Margin="0,20,0,16"/>

                    <TextBlock x:Name="ChangePassTitle" Text="Cambiar master password" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock x:Name="NewPassLabel" Text="Nueva master password:" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="NewMasterPwd" Width="300" HorizontalAlignment="Left"
                                 Padding="8,6"
                                 Background="{StaticResource BackgroundLightBrush}"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 BorderThickness="1"/>
                    <TextBlock x:Name="ConfirmPassLabel" Text="Confirmar:" Margin="0,8,0,4"/>
                    <PasswordBox x:Name="ConfirmMasterPwd" Width="300" HorizontalAlignment="Left"
                                 Padding="8,6"
                                 Background="{StaticResource BackgroundLightBrush}"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 BorderThickness="1"/>
                    <TextBlock x:Name="VaultError" Text="" Foreground="{StaticResource VerdictBlockBrush}"
                               FontSize="11" Margin="0,6,0,0" Visibility="Collapsed"/>
                    <Button x:Name="ChangePassBtn" Content="Cambiar password" Margin="0,10,0,0"
                            HorizontalAlignment="Left" Padding="14,7"
                            Click="ChangePassword_Click"/>
                </StackPanel>

                <!-- ── GENERAL ── -->
                <StackPanel x:Name="PanelGeneral" Visibility="Collapsed">
                    <TextBlock x:Name="GeneralTitle" Text="General" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <TextBlock x:Name="DefBrowserTitle" Text="Navegador predeterminado" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock x:Name="DefBrowserHelp" TextWrapping="Wrap" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"
                               Text="VELO se abrirá cuando hagas clic en enlaces desde email, apps y documentos. Windows 11 requiere que confirmes el cambio en Configuración del sistema."/>
                    <Button x:Name="SetDefaultBrowserButton"
                            Content="Establecer VELO como navegador predeterminado"
                            HorizontalAlignment="Left" Padding="14,8"
                            AutomationProperties.Name="Establecer VELO como navegador predeterminado"
                            AutomationProperties.HelpText="Abre la pantalla de Configuración de Windows para establecer VELO como tu navegador predeterminado"
                            Click="SetDefaultBrowser_Click"/>
                    <TextBlock x:Name="DefaultBrowserStatus" Margin="0,8,0,0"
                               FontSize="11" Visibility="Collapsed" TextWrapping="Wrap"/>

                    <!-- v2.4.23 — clipboard history toggle -->
                    <Border Background="{StaticResource BorderBrush}" Height="1" Margin="0,20,0,16"/>
                    <CheckBox x:Name="ClipboardHistoryCheck" Margin="0,0,0,4">
                        <StackPanel>
                            <TextBlock x:Name="ClipboardHistoryTitle" Text="Historial del portapapeles" FontWeight="SemiBold"/>
                            <TextBlock x:Name="ClipboardHistoryDesc"
                                       Text="Captura los últimos 20 textos copiados. Solo en memoria; se borra al cerrar VELO. Atajo: Ctrl+Shift+V."
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </CheckBox>
                </StackPanel>

                <!-- ── IDIOMA ── -->
                <StackPanel x:Name="PanelIdioma" Visibility="Collapsed">
                    <TextBlock x:Name="LangTitle" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock x:Name="LangSubtitle" FontSize="12" Margin="0,0,0,24"
                               TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}"/>

                    <TextBlock x:Name="LangChooseLabel" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <ComboBox x:Name="LanguagePicker" Width="220" HorizontalAlignment="Left"
                              SelectionChanged="LanguagePicker_Changed"/>
                </StackPanel>

                <!-- ── COUNCIL (Phase 4.0 — UI shell; runtime in v2.5.x) ── -->
                <StackPanel x:Name="PanelCouncil" Visibility="Collapsed">
                    <TextBlock Text="Council Mode" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="Cuatro modelos IA en paralelo. Síntesis 100% local."
                               FontSize="12.5"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,22"/>

                    <!-- Status banner: refreshed via CheckCouncilStatus_Click -->
                    <Border x:Name="CouncilStatusBanner"
                            Style="{StaticResource Card}"
                            Background="{StaticResource SurfaceDarkBrush}"
                            Padding="14,12" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="SÍNTESIS LOCAL (qwen3:32b)"
                                       FontSize="10.5" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="CouncilStatusIcon" Text="?" FontSize="16"
                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock x:Name="CouncilStatusText"
                                           Text="Comprobá con el botón de la derecha si Ollama y qwen3:32b están listos."
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"
                                           MaxWidth="320"/>
                            </StackPanel>
                            <Button x:Name="CheckCouncilStatusButton"
                                    Style="{StaticResource GhostButton}"
                                    Content="Verificar Ollama"
                                    Padding="14,7" FontSize="12"
                                    HorizontalAlignment="Left"
                                    Margin="0,12,0,0"
                                    Click="CheckCouncilStatus_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Per-provider opt-in. Disabled until v2.5.x (Phase 4.1) -->
                    <TextBlock Text="PROVEEDORES (activables en v2.5.x)"
                               FontSize="10.5" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,0,0,10"/>

                    <CheckBox x:Name="CouncilEnabledClaudeCheck"
                              IsEnabled="False" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Claude (Anthropic)" FontWeight="SemiBold"/>
                            <TextBlock Text="Vía claude.ai. Tu prompt llega a Anthropic."
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </CheckBox>

                    <CheckBox x:Name="CouncilEnabledChatGptCheck"
                              IsEnabled="False" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="ChatGPT (OpenAI)" FontWeight="SemiBold"/>
                            <TextBlock Text="Vía chat.openai.com. Tu prompt entra al pipeline de OpenAI."
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </CheckBox>

                    <CheckBox x:Name="CouncilEnabledGrokCheck"
                              IsEnabled="False" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Grok (xAI)" FontWeight="SemiBold"/>
                            <TextBlock Text="Vía grok.com. Necesita sesión activa de X/Twitter."
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </CheckBox>

                    <CheckBox x:Name="CouncilEnabledOllamaCheck"
                              IsEnabled="False" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Ollama (local)" FontWeight="SemiBold"/>
                            <TextBlock Text="100% local. También corre la síntesis final."
                                       FontSize="11" Foreground="{StaticResource BadgeGreenBrush}"/>
                        </StackPanel>
                    </CheckBox>

                    <Border Background="{StaticResource BorderSubtleBrush}" Height="1" Margin="0,12,0,16"/>

                    <TextBlock x:Name="CouncilDisclaimerStatus"
                               FontSize="11.5"
                               Foreground="{StaticResource TextMutedBrush}"
                               TextWrapping="Wrap"/>
                    <Button x:Name="CouncilResetDisclaimerButton"
                            Style="{StaticResource GhostButton}"
                            Content="Mostrar disclaimer otra vez"
                            Padding="14,7" FontSize="11.5"
                            HorizontalAlignment="Left"
                            Margin="0,12,0,0"
                            Click="ResetCouncilDisclaimer_Click"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Bottom bar -->
        <Border Grid.Column="1" Grid.Row="1"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="32,12">
            <Grid>
                <TextBlock x:Name="StatusText" Text=""
                           Foreground="{StaticResource VerdictSafeBrush}"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelButton" Content="Cancelar" Padding="16,8" Margin="0,0,8,0"
                            Click="Cancel_Click"/>
                    <Button x:Name="SaveButton" Content="Guardar" Padding="16,8"
                            Style="{StaticResource AccentButton}"
                            Click="Save_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
