<Window x:Class="VELO.UI.Dialogs.VaultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VELO — Password Vault"
        Width="680" Height="520"
        MinWidth="560" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundDarkBrush}">

        <!-- ── LOCKED OVERLAY (Phase 5.0 re-skin — frame 3) ── -->
        <Grid x:Name="LockScreen"
              Background="{StaticResource BackgroundDarkestBrush}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="380">

                <!-- Shield icon — circular surface with purple glow -->
                <Border Width="92" Height="92" CornerRadius="46"
                        HorizontalAlignment="Center"
                        Background="{StaticResource SurfaceLightBrush}"
                        BorderBrush="{StaticResource AccentPurpleBrush}"
                        BorderThickness="2"
                        Margin="0,0,0,22">
                    <Border.Effect>
                        <DropShadowEffect Color="#7C5CFF" Opacity="0.55"
                                          BlurRadius="36" ShadowDepth="0"/>
                    </Border.Effect>
                    <TextBlock Text="🛡" FontSize="46"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Title -->
                <TextBlock Text="Password Vault" FontSize="26" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>

                <!-- Subtitle -->
                <TextBlock x:Name="UnlockSubtitle"
                           FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" TextWrapping="Wrap"
                           TextAlignment="Center" Margin="0,0,0,30"/>

                <!-- Master password label -->
                <TextBlock x:Name="MasterLabel"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="2,0,0,8"/>

                <!-- Password input (purple focus border + rounded 10px) -->
                <PasswordBox x:Name="UnlockPwd"
                             Style="{StaticResource ModernPasswordBox}"
                             FontSize="14"
                             KeyDown="UnlockPwd_KeyDown"/>

                <!-- Error message -->
                <TextBlock x:Name="UnlockError" Text=""
                           Foreground="{StaticResource BadgeRedBrush}"
                           FontSize="12" Margin="2,8,0,0" Visibility="Collapsed"/>

                <!-- Full-width gradient unlock button -->
                <Button x:Name="UnlockBtn" Margin="0,20,0,0"
                        Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Stretch"
                        Click="Unlock_Click"/>

                <!-- Footer: green dot + "Local encrypted vault" caption -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                            Margin="0,32,0,0">
                    <Ellipse Width="8" Height="8"
                             Fill="{StaticResource BadgeGreenBrush}"
                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="VaultFooter"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11.5" VerticalAlignment="Center"/>
                </StackPanel>

            </StackPanel>
        </Grid>

        <!-- ── MAIN VAULT UI ── -->
        <Grid x:Name="VaultScreen" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Header -->
                <RowDefinition Height="Auto"/>  <!-- Search -->
                <RowDefinition Height="*"/>     <!-- List -->
                <RowDefinition Height="Auto"/>  <!-- Status -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="20,16,20,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔑 Password Vault" FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="EntryCount" Text=""
                               FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="AddBtn" Content="+ Agregar" Style="{StaticResource PrimaryButton}"
                            Padding="14,7" Margin="0,0,8,0" Click="Add_Click"/>
                    <Button x:Name="LockBtn" Content="🔒 Bloquear"
                            Style="{StaticResource GhostButton}"
                            Padding="14,7" Click="Lock_Click"/>
                </StackPanel>
            </Grid>

            <!-- Search -->
            <Border Grid.Row="1" Margin="20,12,20,0"
                    Background="{StaticResource SurfaceLightBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1" CornerRadius="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="🔍" FontSize="14"
                               VerticalAlignment="Center" Margin="14,0,8,0"
                               Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBox x:Name="SearchBox" Grid.Column="1"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             CaretBrush="{StaticResource AccentPurpleBrush}"
                             SelectionBrush="{StaticResource AccentPurpleBrush}"
                             Padding="0,11,12,11" FontSize="13"
                             TextChanged="Search_Changed"/>
                </Grid>
            </Border>

            <!-- Entry list -->
            <ScrollViewer Grid.Row="2" Margin="20,12,20,0"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="EntryList"/>
            </ScrollViewer>

            <!-- Status bar -->
            <Border Grid.Row="3" BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="0,1,0,0" Padding="20,10">
                <TextBlock x:Name="StatusText" Text=""
                           Foreground="{StaticResource BadgeGreenBrush}" FontSize="11.5"/>
            </Border>
        </Grid>

        <!-- ── ADD / EDIT PANEL ── -->
        <Grid x:Name="EditScreen" Visibility="Collapsed"
              Background="{StaticResource BackgroundDarkestBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Edit header -->
            <Grid Grid.Row="0" Margin="24,16,24,0">
                <TextBlock x:Name="EditTitle" Text="Nueva entrada"
                           FontSize="16" FontWeight="SemiBold"/>
                <Button x:Name="BackBtn" Content="← Volver" HorizontalAlignment="Right"
                        Padding="10,5" Click="BackToList_Click"/>
            </Grid>

            <!-- Edit form -->
            <ScrollViewer Grid.Row="1" Padding="24,16,24,0"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock x:Name="SiteLabel" Text="Sitio" Margin="0,0,0,4"/>
                    <TextBox x:Name="EditSiteName" Margin="0,0,0,4"
                             TextChanged="RequiredField_Changed"/>
                    <TextBlock x:Name="SiteError"
                               Text="✦ Este campo es obligatorio"
                               Foreground="{StaticResource BadgeRedBrush}" FontSize="10.5"
                               Visibility="Collapsed" Margin="2,0,0,8"/>

                    <TextBlock x:Name="UrlLabel" Text="URL" Margin="0,0,0,4"/>
                    <TextBox x:Name="EditUrl" Margin="0,0,0,12"/>

                    <TextBlock x:Name="UsernameLabel" Text="Usuario / Email" Margin="0,0,0,4"/>
                    <TextBox x:Name="EditUsername" Margin="0,0,0,4"
                             TextChanged="RequiredField_Changed"/>
                    <TextBlock x:Name="UsernameError"
                               Text="✦ Este campo es obligatorio"
                               Foreground="{StaticResource BadgeRedBrush}" FontSize="10.5"
                               Visibility="Collapsed" Margin="2,0,0,8"/>

                    <TextBlock x:Name="PasswordLabel" Text="Contraseña" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="EditPassword" Grid.Column="0"
                                 TextChanged="RequiredField_Changed"/>
                        <Button x:Name="TogglePasswordBtn" Content="👁" Grid.Column="1" Padding="8,0"
                                Margin="4,0,0,0" ToolTip="Mostrar/Ocultar"
                                Click="TogglePasswordVisible_Click"/>
                        <Button x:Name="GenerateBtn" Content="⚡ Generar" Grid.Column="2" Padding="10,0"
                                Margin="4,0,0,0" Click="GeneratePassword_Click"/>
                    </Grid>

                    <!-- Password strength bar -->
                    <Grid Margin="0,4,0,6" Height="5">
                        <Rectangle Fill="{StaticResource SurfaceLightBrush}" RadiusX="2.5" RadiusY="2.5"/>
                        <Rectangle x:Name="StrengthBar" HorizontalAlignment="Left"
                                   RadiusX="2.5" RadiusY="2.5" Width="0"/>
                    </Grid>
                    <TextBlock x:Name="PasswordError"
                               Text="✦ Este campo es obligatorio"
                               Foreground="{StaticResource BadgeRedBrush}" FontSize="10.5"
                               Visibility="Collapsed" Margin="2,0,0,8"/>

                    <!-- Generator options -->
                    <Border x:Name="GeneratorPanel" Visibility="Collapsed"
                            Style="{StaticResource Card}"
                            Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock x:Name="GeneratorTitleLabel" Text="Generador de contraseña" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="LengthTitleLabel" Text="Longitud:" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Slider x:Name="LengthSlider" Minimum="8" Maximum="64"
                                            Value="24" Width="120" VerticalAlignment="Center"
                                            ValueChanged="LengthSlider_Changed"/>
                                    <TextBlock x:Name="LengthLabel" Text="24"
                                               VerticalAlignment="Center" Margin="8,0,0,0" Width="24"/>
                                </StackPanel>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <CheckBox x:Name="GenUppercase" Content="Mayúsculas" IsChecked="True" Margin="0,0,12,0"/>
                                <CheckBox x:Name="GenNumbers"   Content="Números"    IsChecked="True" Margin="0,0,12,0"/>
                                <CheckBox x:Name="GenSymbols"   Content="Símbolos"   IsChecked="True"/>
                            </StackPanel>
                            <Button x:Name="RegenerateBtn" Content="Regenerar" Margin="0,10,0,0"
                                    HorizontalAlignment="Left" Padding="12,6"
                                    Click="GeneratePassword_Click"/>
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="NotesLabel" Text="Notas (opcional)" Margin="0,0,0,4"/>
                    <TextBox x:Name="EditNotes" Height="60"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Edit buttons -->
            <Border Grid.Row="2" BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="0,1,0,0" Padding="24,14">
                <Grid>
                    <Button x:Name="DeleteBtn" Content="🗑 Eliminar"
                            Foreground="{StaticResource BadgeRedBrush}"
                            HorizontalAlignment="Left" Padding="12,8"
                            Visibility="Collapsed" Click="Delete_Click"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="CancelBtn" Content="Cancelar"
                                Style="{StaticResource GhostButton}"
                                Padding="16,8" Margin="0,0,8,0"
                                Click="BackToList_Click"/>
                        <Button x:Name="SaveBtn" Content="Guardar"
                                Style="{StaticResource PrimaryButton}"
                                Padding="20,9" Click="SaveEntry_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Window>
