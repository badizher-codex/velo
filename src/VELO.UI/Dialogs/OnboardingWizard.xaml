<Window x:Class="VELO.UI.Dialogs.OnboardingWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VELO — Configuración inicial"
        Width="480" Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Closing="Window_Closing">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundDarkBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="*"/>      <!-- Content -->
            <RowDefinition Height="Auto"/>   <!-- Navigation buttons -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="32,28,32,0">
            <TextBlock Text="VELO"
                       FontSize="28" FontWeight="Light"
                       Foreground="{StaticResource AccentBlueBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock x:Name="StepIndicator"
                       Text="Paso 1 de 4"
                       FontSize="11"
                       Foreground="{StaticResource TextMutedBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Step panels (only one visible at a time) -->
        <Grid Grid.Row="1" Margin="32,24,32,0">

            <!-- Step 1: AI Mode -->
            <StackPanel x:Name="Step1" Visibility="Visible">
                <TextBlock Text="Elige cómo VELO analiza amenazas"
                           FontSize="17" FontWeight="SemiBold" Margin="0,0,0,20"/>

                <RadioButton x:Name="RadioOffline" GroupName="AIMode"
                             IsChecked="True" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Offline (Recomendado)" FontWeight="SemiBold"/>
                        <TextBlock Text="100% local. Sin API key. Seguro para uso diario."
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="RadioClaude" GroupName="AIMode" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Claude (Mejor detección)" FontWeight="SemiBold"/>
                        <TextBlock Text="Requiere API key de Anthropic. Análisis más profundo."
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </RadioButton>

                <TextBox x:Name="ApiKeyField"
                         Margin="20,0,0,16"
                         
                         IsEnabled="False"/>

                <RadioButton x:Name="RadioCustom" GroupName="AIMode" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="LLM Personalizado" FontWeight="SemiBold"/>
                        <TextBlock Text="Ollama u otro endpoint compatible."
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </RadioButton>

                <TextBox x:Name="CustomEndpointField"
                         Margin="20,0,0,4"
                         
                         IsEnabled="False"/>
                <TextBox x:Name="CustomModelField"
                         Margin="20,4,0,0"
                         
                         IsEnabled="False"/>
            </StackPanel>

            <!-- Step 2: DNS -->
            <StackPanel x:Name="Step2" Visibility="Collapsed">
                <TextBlock Text="DNS Privado"
                           FontSize="17" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock Text="Tu ISP puede ver qué sitios visitas con DNS normal. VELO usa DNS encriptado (DoH)."
                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,20"/>

                <RadioButton x:Name="DnsQuad9" GroupName="DNS" IsChecked="True" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Quad9 (Recomendado)" FontWeight="SemiBold"/>
                        <TextBlock Text="Sin logs · Bloquea malware · Suiza"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </RadioButton>
                <RadioButton x:Name="DnsCloudflare" GroupName="DNS" Margin="0,0,0,12">
                    <TextBlock Text="Cloudflare 1.1.1.1"/>
                </RadioButton>
                <RadioButton x:Name="DnsNextDns" GroupName="DNS" Margin="0,0,0,12">
                    <TextBlock Text="NextDNS"/>
                </RadioButton>
                <RadioButton x:Name="DnsCustom" GroupName="DNS" Margin="0,0,0,8">
                    <TextBlock Text="Personalizado"/>
                </RadioButton>
                <TextBox x:Name="DnsCustomUrl"
                         Margin="20,0,0,0"
                         
                         IsEnabled="False"/>
            </StackPanel>

            <!-- Step 3: Fingerprint -->
            <StackPanel x:Name="Step3" Visibility="Collapsed">
                <TextBlock Text="Protección de Identidad"
                           FontSize="17" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock Text="Los sitios pueden identificarte sin cookies usando tu 'huella digital' del navegador."
                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,20"/>

                <TextBlock Text="VELO ya tiene activada:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock Text="✓ Protección Canvas" Foreground="{StaticResource VerdictSafeBrush}" Margin="0,4"/>
                <TextBlock Text="✓ Spoof de hardware" Foreground="{StaticResource VerdictSafeBrush}" Margin="0,4"/>
                <TextBlock Text="✓ Rotación de User Agent" Foreground="{StaticResource VerdictSafeBrush}" Margin="0,4"/>
                <TextBlock Text="✓ Protección WebRTC" Foreground="{StaticResource VerdictSafeBrush}" Margin="0,4"/>

                <TextBlock Text="Nivel: AGRESIVO (óptimo)" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBlueBrush}" Margin="0,16,0,0"/>
                <TextBlock Text="Puedes cambiarlo en Settings en cualquier momento."
                           FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,4"/>
            </StackPanel>

            <!-- Step 4: Master Password -->
            <StackPanel x:Name="Step4" Visibility="Collapsed">
                <TextBlock Text="Password Vault"
                           FontSize="17" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock Text="VELO incluye un gestor de contraseñas encriptado. Elige una master password para protegerlo."
                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,20"/>

                <TextBlock Text="Master password (mínimo 8 caracteres):" Margin="0,0,0,6"/>
                <PasswordBox x:Name="MasterPasswordField" Margin="0,0,0,12"
                             Padding="8,6"
                             Background="{StaticResource BackgroundLightBrush}"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             BorderThickness="1"/>

                <TextBlock Text="Confirmar password:" Margin="0,0,0,6"/>
                <PasswordBox x:Name="ConfirmPasswordField"
                             Padding="8,6"
                             Background="{StaticResource BackgroundLightBrush}"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             BorderThickness="1"/>

                <TextBlock x:Name="PasswordError"
                           Text=""
                           Foreground="{StaticResource VerdictBlockBrush}"
                           FontSize="11"
                           Margin="0,8,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>
        </Grid>

        <!-- Navigation buttons -->
        <Grid Grid.Row="2" Margin="32,16,32,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="BackBtn" Grid.Column="1"
                    Content="← Atrás" Padding="16,8"
                    Click="Back_Click"
                    Visibility="Hidden"/>
            <Button x:Name="NextBtn" Grid.Column="3"
                    Content="Continuar →" Padding="16,8"
                    Style="{StaticResource AccentButton}"
                    Click="Next_Click"/>
        </Grid>
    </Grid>
</Window>
