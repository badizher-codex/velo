<Window x:Class="VELO.UI.Dialogs.OnboardingWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VELO — Configuración inicial"
        Width="480" Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Closing="Window_Closing">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundDarkestBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="*"/>      <!-- Content -->
            <RowDefinition Height="Auto"/>   <!-- Navigation buttons -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="32,28,32,0">
            <TextBlock Text="VELO"
                       FontSize="28" FontWeight="Light"
                       Foreground="{StaticResource AccentPurpleLightBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock x:Name="StepIndicator"
                       Text="Paso 1 de 4"
                       FontSize="11"
                       Foreground="{StaticResource TextMutedBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Step panels (only one visible at a time) -->
        <Grid Grid.Row="1" Margin="32,24,32,0">

            <!-- Step 1: AI Mode -->
            <StackPanel x:Name="Step1" Visibility="Visible">
                <TextBlock x:Name="Step1Title" Text="Elige cómo VELO analiza amenazas"
                           FontSize="17" FontWeight="SemiBold" Margin="0,0,0,20"/>

                <RadioButton x:Name="RadioOffline" GroupName="AIMode"
                             IsChecked="True" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock x:Name="OfflineTitle" Text="Offline (Recomendado)" FontWeight="SemiBold"/>
                        <TextBlock x:Name="OfflineDesc" Text="100% local. Sin API key. Seguro para uso diario."
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="RadioClaude" GroupName="AIMode" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock x:Name="ClaudeTitle" Text="Claude (Mejor detección)" FontWeight="SemiBold"/>
                        <TextBlock x:Name="ClaudeDesc" Text="Requiere API key de Anthropic. Análisis más profundo."
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </RadioButton>

                <TextBox x:Name="ApiKeyField"
                         Margin="20,0,0,16"
                         IsEnabled="False"/>

                <RadioButton x:Name="RadioCustom" GroupName="AIMode" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock x:Name="CustomTitle" Text="LLM Personalizado" FontWeight="SemiBold"/>
                        <TextBlock x:Name="CustomDesc" Text="Ollama u otro endpoint compatible."
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </RadioButton>

                <TextBox x:Name="CustomEndpointField"
                         Margin="20,0,0,4"
                         IsEnabled="False"/>
                <TextBox x:Name="CustomModelField"
                         Margin="20,4,0,0"
                         IsEnabled="False"/>
            </StackPanel>

            <!-- Step 2: DNS -->
            <StackPanel x:Name="Step2" Visibility="Collapsed">
                <TextBlock x:Name="Step2Title" Text="DNS Privado"
                           FontSize="17" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock x:Name="Step2Intro" Text="Tu ISP puede ver qué sitios visitas con DNS normal. VELO usa DNS encriptado (DoH)."
                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,20"/>

                <RadioButton x:Name="DnsQuad9" GroupName="DNS" IsChecked="True" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock x:Name="Quad9Title" Text="Quad9 (Recomendado)" FontWeight="SemiBold"/>
                        <TextBlock x:Name="Quad9Desc" Text="Sin logs · Bloquea malware · Suiza"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </RadioButton>
                <RadioButton x:Name="DnsCloudflare" GroupName="DNS" Margin="0,0,0,12">
                    <TextBlock Text="Cloudflare 1.1.1.1"/>
                </RadioButton>
                <RadioButton x:Name="DnsNextDns" GroupName="DNS" Margin="0,0,0,12">
                    <TextBlock Text="NextDNS"/>
                </RadioButton>
                <RadioButton x:Name="DnsCustom" GroupName="DNS" Margin="0,0,0,8">
                    <TextBlock x:Name="DnsCustomLabel" Text="Personalizado"/>
                </RadioButton>
                <TextBox x:Name="DnsCustomUrl"
                         Margin="20,0,0,0"
                         IsEnabled="False"/>
            </StackPanel>

            <!-- Step 3: Fingerprint -->
            <StackPanel x:Name="Step3" Visibility="Collapsed">
                <TextBlock x:Name="Step3Title" Text="Protección de Identidad"
                           FontSize="17" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock x:Name="Step3Intro" Text="Los sitios pueden identificarte sin cookies usando tu 'huella digital' del navegador."
                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,20"/>

                <TextBlock x:Name="AlreadyOn" Text="VELO ya tiene activada:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock x:Name="ProtCanvas"   Text="✓ Protección Canvas" Foreground="{StaticResource BadgeGreenBrush}" Margin="0,4"/>
                <TextBlock x:Name="ProtHardware" Text="✓ Spoof de hardware" Foreground="{StaticResource BadgeGreenBrush}" Margin="0,4"/>
                <TextBlock x:Name="ProtUa"       Text="✓ Rotación de User Agent" Foreground="{StaticResource BadgeGreenBrush}" Margin="0,4"/>
                <TextBlock x:Name="ProtWebrtc"   Text="✓ Protección WebRTC" Foreground="{StaticResource BadgeGreenBrush}" Margin="0,4"/>

                <TextBlock x:Name="LevelLine" Text="Nivel: AGRESIVO (óptimo)" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentPurpleLightBrush}" Margin="0,16,0,0"/>
                <TextBlock x:Name="ChangeableLine" Text="Puedes cambiarlo en Settings en cualquier momento."
                           FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,4"/>
            </StackPanel>

            <!-- Step 4: Master Password -->
            <StackPanel x:Name="Step4" Visibility="Collapsed">
                <TextBlock x:Name="Step4Title" Text="Password Vault"
                           FontSize="17" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock x:Name="Step4Intro" Text="VELO incluye un gestor de contraseñas encriptado. Elige una master password para protegerlo."
                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,20"/>

                <TextBlock x:Name="MasterLabel" Text="Master password (mínimo 8 caracteres):" Margin="0,0,0,6"/>
                <PasswordBox x:Name="MasterPasswordField"
                             Style="{StaticResource ModernPasswordBox}"
                             Margin="0,0,0,12"/>

                <TextBlock x:Name="ConfirmLabel" Text="Confirmar password:" Margin="0,0,0,6"/>
                <PasswordBox x:Name="ConfirmPasswordField"
                             Style="{StaticResource ModernPasswordBox}"/>

                <TextBlock x:Name="PasswordError"
                           Text=""
                           Foreground="{StaticResource BadgeRedBrush}"
                           FontSize="11"
                           Margin="0,8,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>
        </Grid>

        <!-- Navigation buttons -->
        <Grid Grid.Row="2" Margin="32,16,32,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="BackBtn" Grid.Column="1"
                    Content="← Atrás"
                    Style="{StaticResource GhostButton}"
                    Padding="18,9"
                    Click="Back_Click"
                    Visibility="Hidden"/>
            <Button x:Name="NextBtn" Grid.Column="3"
                    Content="Continuar →"
                    Style="{StaticResource PrimaryButton}"
                    Padding="20,9"
                    Click="Next_Click"/>
        </Grid>
    </Grid>
</Window>
