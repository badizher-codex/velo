<Window x:Class="VELO.UI.Dialogs.ClearDataWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Limpiar datos — VELO"
        Width="480" Height="540"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundDarkestBrush}"
        Foreground="{StaticResource TextPrimaryBrush}">

    <!-- Phase 5.0 re-skin — frame 7 left. -->
    <Grid Margin="32,28,32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header (icon + title) -->
            <RowDefinition Height="Auto"/>  <!-- Subtitle -->
            <RowDefinition Height="*"/>     <!-- Checklist -->
            <RowDefinition Height="Auto"/>  <!-- Status -->
            <RowDefinition Height="Auto"/>  <!-- Actions -->
        </Grid.RowDefinitions>

        <!-- Header: trash icon in a circular danger surface + title -->
        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,0,0,14">
            <Border Width="56" Height="56" CornerRadius="28"
                    Background="{StaticResource BadgeRedBgBrush}"
                    BorderBrush="{StaticResource BadgeRedBrush}"
                    BorderThickness="1"
                    Margin="0,0,16,0">
                <TextBlock Text="🗑" FontSize="26"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="TitleLabel"
                       FontSize="22" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Subtitle -->
        <TextBlock Grid.Row="1"
                   x:Name="SubtitleLabel"
                   FontSize="13"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   HorizontalAlignment="Center" TextAlignment="Center"
                   TextWrapping="Wrap" Margin="0,0,0,22"/>

        <!-- Checklist — each option wrapped in a card -->
        <StackPanel Grid.Row="2">

            <Border Style="{StaticResource Card}" Padding="14,12" Margin="0,0,0,8">
                <CheckBox x:Name="ClearHistoryCheck" IsChecked="True">
                    <StackPanel>
                        <TextBlock x:Name="ClearHistoryLabel" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="ClearHistoryDesc"
                                   FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap" Margin="0,3,0,0"/>
                    </StackPanel>
                </CheckBox>
            </Border>

            <Border Style="{StaticResource Card}" Padding="14,12" Margin="0,0,0,8">
                <CheckBox x:Name="ClearCookiesCheck" IsChecked="False">
                    <StackPanel>
                        <TextBlock x:Name="ClearCookiesLabel" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="ClearCookiesDesc"
                                   FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap" Margin="0,3,0,0"/>
                    </StackPanel>
                </CheckBox>
            </Border>

            <Border Style="{StaticResource Card}" Padding="14,12" Margin="0,0,0,8">
                <CheckBox x:Name="ClearCacheCheck" IsChecked="False">
                    <StackPanel>
                        <TextBlock x:Name="ClearCacheLabel" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="ClearCacheDesc"
                                   FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap" Margin="0,3,0,0"/>
                    </StackPanel>
                </CheckBox>
            </Border>

            <Border Style="{StaticResource Card}" Padding="14,12">
                <CheckBox x:Name="ClearDownloadsCheck" IsChecked="False">
                    <StackPanel>
                        <TextBlock x:Name="ClearDownloadsLabel" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="ClearDownloadsDesc"
                                   FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap" Margin="0,3,0,0"/>
                    </StackPanel>
                </CheckBox>
            </Border>

        </StackPanel>

        <!-- Status -->
        <TextBlock Grid.Row="3" x:Name="StatusLabel"
                   FontSize="12" Margin="0,16,0,0" Visibility="Collapsed"
                   Foreground="{StaticResource TextMutedBrush}"
                   HorizontalAlignment="Center"/>

        <!-- Actions: ghost cancel + danger clear -->
        <Grid Grid.Row="4" Margin="0,22,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="CancelButton" Grid.Column="0"
                    Style="{StaticResource GhostButton}"
                    HorizontalAlignment="Stretch"
                    Margin="0,0,6,0"
                    Click="OnCancelClick"/>
            <Button x:Name="ClearButton" Grid.Column="1"
                    Style="{StaticResource DangerButton}"
                    HorizontalAlignment="Stretch"
                    Margin="6,0,0,0"
                    Click="OnClearClick"/>
        </Grid>
    </Grid>
</Window>
