<Window x:Class="VELO.UI.Dialogs.SecurityInspectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VELO Security Inspector"
        Background="#FF0D0D0D"
        Foreground="#FFFFFFFF"
        MinWidth="700" MinHeight="550"
        Width="760" Height="640"
        WindowStartupLocation="CenterOwner"
        AutomationProperties.Name="VELO Security Inspector"
        AutomationProperties.HelpText="Análisis de seguridad y privacidad del sitio activo">

    <Window.Resources>
        <Style x:Key="SectionBorder" TargetType="Border">
            <Setter Property="Background"       Value="#FF181818"/>
            <Setter Property="BorderBrush"      Value="#FF2A2A2A"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="6"/>
            <Setter Property="Padding"          Value="14,10"/>
            <Setter Property="Margin"           Value="0,0,0,10"/>
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#FF666666"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Margin"      Value="0,0,0,8"/>
            <Setter Property="Text"        Value="SECCIÓN"/>
        </Style>
        <Style x:Key="DataRow" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Margin"      Value="0,2"/>
        </Style>
        <Style x:Key="DataLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#FFB0B0B0"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="MinWidth"    Value="160"/>
        </Style>
        <Style x:Key="DataValue" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#FFFFFFFF"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background"       Value="#FF252525"/>
            <Setter Property="Foreground"       Value="#FFB0B0B0"/>
            <Setter Property="BorderBrush"      Value="#FF3A3A3A"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="12,7"/>
            <Setter Property="Margin"           Value="0,0,8,0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FontSize"         Value="12"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header -->
            <RowDefinition Height="*"/>     <!-- scrollable body -->
            <RowDefinition Height="Auto"/>  <!-- action bar -->
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="#FF111111"
                BorderBrush="#FF2A2A2A"
                BorderThickness="0,0,0,1"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Shield badge -->
                <Border x:Name="ShieldBadgeBorder"
                        Grid.Column="0"
                        Background="#FF1A3A20"
                        BorderBrush="#FF2EB54F"
                        BorderThickness="1.5"
                        CornerRadius="6"
                        Padding="10,6"
                        Margin="0,0,14,0"
                        VerticalAlignment="Center"
                        AutomationProperties.Name="Nivel de seguridad del sitio">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="ShieldIcon" Text="🛡" FontSize="18" VerticalAlignment="Center"/>
                        <StackPanel Margin="6,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="ShieldLevelText" Text="Verde" FontSize="13" FontWeight="SemiBold" Foreground="#FF2EB54F"/>
                            <TextBlock x:Name="ShieldScoreText" Text="Score: +0" FontSize="10" Foreground="#FF666666"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Domain + URL -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="DomainText"
                               FontSize="16" FontWeight="SemiBold" Foreground="#FFFFFFFF"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="UrlText"
                               FontSize="11" Foreground="#FF666666"
                               TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Timestamp -->
                <TextBlock x:Name="TimestampText"
                           Grid.Column="2"
                           FontSize="10" Foreground="#FF444444"
                           VerticalAlignment="Bottom" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- ── Scrollable body ────────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="20,14">

                <!-- TLS / Certificado -->
                <Border Style="{StaticResource SectionBorder}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="TLS / CERTIFICADO"/>
                        <StackPanel x:Name="TlsPanel"/>
                    </StackPanel>
                </Border>

                <!-- Bloqueos en esta sesión -->
                <Border Style="{StaticResource SectionBorder}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="BLOQUEOS EN ESTA SESIÓN"/>
                        <StackPanel x:Name="BlocksPanel"/>
                    </StackPanel>
                </Border>

                <!-- Análisis IA -->
                <Border Style="{StaticResource SectionBorder}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="ANÁLISIS DE INTELIGENCIA ARTIFICIAL"/>
                        <StackPanel x:Name="AiPanel"/>
                    </StackPanel>
                </Border>

                <!-- Protección de huella digital -->
                <Border Style="{StaticResource SectionBorder}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="PROTECCIÓN DE HUELLA DIGITAL"/>
                        <StackPanel x:Name="FingerprintPanel"/>
                    </StackPanel>
                </Border>

                <!-- Motivos del score -->
                <Border x:Name="ReasonsSection" Style="{StaticResource SectionBorder}" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="DETALLES DEL SHIELD SCORE"/>
                        <StackPanel x:Name="ReasonsPanel"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ── Action bar ─────────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="#FF111111"
                BorderBrush="#FF2A2A2A"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="DevToolsButton"
                        Style="{StaticResource ActionButton}"
                        Content="🔧 Abrir DevTools nativos"
                        Click="DevTools_Click"
                        AutomationProperties.Name="Abrir DevTools nativos de Chromium"
                        ToolTip="Ctrl+Shift+I en DevTools"/>
                <Button x:Name="ExportButton"
                        Style="{StaticResource ActionButton}"
                        Content="📋 Exportar JSON"
                        Click="Export_Click"
                        AutomationProperties.Name="Exportar análisis como JSON"/>
                <Button x:Name="RescanButton"
                        Style="{StaticResource ActionButton}"
                        Content="🔄 Re-escanear"
                        Click="Rescan_Click"
                        AutomationProperties.Name="Forzar re-escaneo de seguridad"/>

                <!-- Spacer -->
                <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                           Foreground="#FF333333" FontSize="10"
                           Margin="0,0,0,0" Text="VELO Security Inspector · Fase 2"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
