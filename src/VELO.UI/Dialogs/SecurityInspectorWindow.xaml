<Window x:Class="VELO.UI.Dialogs.SecurityInspectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VELO Security Inspector"
        Background="{StaticResource BackgroundDarkestBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        MinWidth="720" MinHeight="580"
        Width="800" Height="680"
        WindowStartupLocation="CenterOwner"
        AutomationProperties.Name="VELO Security Inspector"
        AutomationProperties.HelpText="Análisis de seguridad y privacidad del sitio activo">

    <!-- Phase 5.1 re-skin — frame 6. Local styles migrated to theme tokens;
         dynamic shield colors stay hardcoded because code-behind switches
         them based on the live ShieldLevel result. -->
    <Window.Resources>
        <Style x:Key="SectionBorder" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="Padding"     Value="16,14"/>
            <Setter Property="Margin"      Value="0,0,0,12"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="FontSize"    Value="10.5"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Margin"      Value="0,0,0,10"/>
            <Setter Property="Text"        Value="SECCIÓN"/>
        </Style>
        <Style x:Key="DataRow" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Margin"      Value="0,3"/>
        </Style>
        <Style x:Key="DataLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="MinWidth"    Value="170"/>
        </Style>
        <Style x:Key="DataValue" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Padding"  Value="14,9"/>
            <Setter Property="Margin"   Value="0,0,8,0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header -->
            <RowDefinition Height="*"/>     <!-- scrollable body -->
            <RowDefinition Height="Auto"/>  <!-- action bar -->
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceDarkBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1"
                Padding="22,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Shield badge — pill shape. Defaults to green; code-behind
                     repaints Background/BorderBrush/Foreground when the level
                     changes (Red / Yellow / Gold variants).  -->
                <Border x:Name="ShieldBadgeBorder"
                        Grid.Column="0"
                        Background="#FF1A3A20"
                        BorderBrush="#FF2EB54F"
                        BorderThickness="1.5"
                        CornerRadius="99"
                        Padding="14,7"
                        Margin="0,0,16,0"
                        VerticalAlignment="Center"
                        AutomationProperties.Name="Nivel de seguridad del sitio">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="ShieldIcon" Text="🛡" FontSize="18" VerticalAlignment="Center"/>
                        <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="ShieldLevelText" Text="Verde" FontSize="13" FontWeight="SemiBold" Foreground="#FF2EB54F"/>
                            <TextBlock x:Name="ShieldScoreText" Text="Score: +0" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Domain + URL -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="DomainText"
                               FontSize="17" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="UrlText"
                               FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               TextTrimming="CharacterEllipsis" Margin="0,3,0,0"/>
                </StackPanel>

                <!-- Timestamp -->
                <TextBlock x:Name="TimestampText"
                           Grid.Column="2"
                           FontSize="10"
                           Foreground="{StaticResource TextMutedBrush}"
                           Opacity="0.7"
                           VerticalAlignment="Bottom" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- ── Scrollable body ────────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="22,16">

                <!-- TLS / Certificado -->
                <Border Style="{StaticResource SectionBorder}">
                    <StackPanel>
                        <TextBlock x:Name="TlsSectionTitle" Style="{StaticResource SectionTitle}" Text="TLS / CERTIFICADO"/>
                        <StackPanel x:Name="TlsPanel"/>
                    </StackPanel>
                </Border>

                <!-- Bloqueos en esta sesión -->
                <Border Style="{StaticResource SectionBorder}">
                    <StackPanel>
                        <TextBlock x:Name="BlocksSectionTitle" Style="{StaticResource SectionTitle}" Text="BLOQUEOS EN ESTA SESIÓN"/>
                        <StackPanel x:Name="BlocksPanel"/>
                    </StackPanel>
                </Border>

                <!-- Análisis IA -->
                <Border Style="{StaticResource SectionBorder}">
                    <StackPanel>
                        <TextBlock x:Name="AiSectionTitle" Style="{StaticResource SectionTitle}" Text="ANÁLISIS DE INTELIGENCIA ARTIFICIAL"/>
                        <StackPanel x:Name="AiPanel"/>
                    </StackPanel>
                </Border>

                <!-- Protección de huella digital -->
                <Border Style="{StaticResource SectionBorder}">
                    <StackPanel>
                        <TextBlock x:Name="FpSectionTitle" Style="{StaticResource SectionTitle}" Text="PROTECCIÓN DE HUELLA DIGITAL"/>
                        <StackPanel x:Name="FingerprintPanel"/>
                    </StackPanel>
                </Border>

                <!-- Motivos del score -->
                <Border x:Name="ReasonsSection" Style="{StaticResource SectionBorder}" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock x:Name="ScoreSectionTitle" Style="{StaticResource SectionTitle}" Text="DETALLES DEL SHIELD SCORE"/>
                        <StackPanel x:Name="ReasonsPanel"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ── Action bar ─────────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{StaticResource SurfaceDarkBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,1,0,0"
                Padding="22,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="DevToolsButton"
                            Style="{StaticResource ActionButton}"
                            Content="🔧 Abrir DevTools nativos"
                            Click="DevTools_Click"
                            AutomationProperties.Name="Abrir DevTools nativos de Chromium"
                            ToolTip="Ctrl+Shift+I en DevTools"/>
                    <Button x:Name="ExportButton"
                            Style="{StaticResource ActionButton}"
                            Content="📋 Exportar JSON"
                            Click="Export_Click"
                            AutomationProperties.Name="Exportar análisis como JSON"/>
                    <Button x:Name="RescanButton"
                            Style="{StaticResource ActionButton}"
                            Content="🔄 Re-escanear"
                            Click="Rescan_Click"
                            AutomationProperties.Name="Forzar re-escaneo de seguridad"/>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextMutedBrush}"
                           Opacity="0.55"
                           FontSize="10"
                           Text="VELO Security Inspector · Fase 2"/>
            </Grid>
        </Border>
    </Grid>
</Window>
