<UserControl x:Class="VELO.UI.Controls.ThreatsPanelV2"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:VELO.UI.Converters"
             Width="380"
             Visibility="Collapsed"
             AutomationProperties.Name="Threats panel">

    <UserControl.Resources>
        <conv:LocalizeKeyConverter x:Key="L"/>
    </UserControl.Resources>

    <Border BorderBrush="#FF3D71"
            BorderThickness="3,0,0,0"
            Background="#1A1A2E"
            CornerRadius="0,6,6,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Header -->
                <RowDefinition Height="Auto"/>   <!-- Summary -->
                <RowDefinition Height="*"/>      <!-- Grouped list -->
                <RowDefinition Height="Auto"/>   <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- ── Header ─────────────────────────────────────────────── -->
            <Border Grid.Row="0"
                    Background="#FF111118"
                    BorderBrush="#FF2A2A3A"
                    BorderThickness="0,0,0,1"
                    Padding="14,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="🛡" FontSize="16"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="HeaderTitle" Grid.Column="1"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="#FFE0E0E8"
                               VerticalAlignment="Center"/>
                    <Button x:Name="CloseButton" Grid.Column="2"
                            Style="{StaticResource IconButton}"
                            Content="✕" FontSize="11"
                            Padding="6,2"
                            Click="Close_Click"/>
                </Grid>
            </Border>

            <!-- ── Summary ────────────────────────────────────────────── -->
            <TextBlock x:Name="SummaryText" Grid.Row="1"
                       FontSize="11"
                       Foreground="#FF8080A0"
                       Padding="14,8"
                       TextWrapping="Wrap"/>

            <!-- ── Grouped list ───────────────────────────────────────── -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="6,4,6,4">
                <ItemsControl x:Name="GroupsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="4,3"
                                    Padding="8"
                                    CornerRadius="6"
                                    BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background"  Value="#FF1E1E2E"/>
                                        <Setter Property="BorderBrush" Value="#FF2A2A3A"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMalwaredexHit}" Value="True">
                                                <Setter Property="BorderBrush" Value="#FFE53E3E"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <!-- Group header (always visible, click toggles expansion) -->
                                    <Border Background="Transparent"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="GroupHeader_Click"
                                            Tag="{Binding Host}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       FontSize="11"
                                                       Foreground="#FF8080A0"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,6,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="▶"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                <Setter Property="Text" Value="▼"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Host}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="#FFD0D0E8"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"/>
                                            <Border Grid.Column="2"
                                                    Background="#FF2A2A3A"
                                                    CornerRadius="8"
                                                    Padding="6,1"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Count}"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="#FFD0D0E8"/>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- Per-entry list (only when expanded) -->
                                    <ItemsControl ItemsSource="{Binding Entries}" Margin="14,6,0,0">
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,4,0,0"
                                                        Padding="6,4"
                                                        Background="#FF14141A"
                                                        CornerRadius="4">
                                                    <StackPanel>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0"
                                                                       Text="{Binding ShortPath}"
                                                                       FontSize="10.5"
                                                                       Foreground="#FFB0B0C0"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding TimeLabel}"
                                                                       FontSize="9.5"
                                                                       Foreground="#FF606080"
                                                                       Margin="6,0,0,0"/>
                                                        </Grid>
                                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                            <Button Content="Explicar"
                                                                    FontSize="10"
                                                                    Padding="6,2"
                                                                    Margin="0,0,4,0"
                                                                    Click="Explain_Click"
                                                                    Tag="{Binding Id}"/>
                                                            <Button Content="Aprobar"
                                                                    FontSize="10"
                                                                    Padding="6,2"
                                                                    Margin="0,0,4,0"
                                                                    Click="Allow_Click"
                                                                    Tag="{Binding Id}"/>
                                                            <Button Content="Reportar"
                                                                    FontSize="10"
                                                                    Padding="6,2"
                                                                    Click="Report_Click"
                                                                    Tag="{Binding Id}"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Explanation, Mode=OneWay}"
                                                                   FontSize="10.5"
                                                                   Foreground="#FF7080B0"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,4,0,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HasExplanation}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- ── Footer ─────────────────────────────────────────────── -->
            <Border Grid.Row="3"
                    Background="#FF111118"
                    BorderBrush="#FF2A2A3A"
                    BorderThickness="0,1,0,0"
                    Padding="10,6">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="ExportButton"
                            Style="{StaticResource IconButton}"
                            Content="📥"
                            FontSize="13"
                            Padding="6,3"
                            Margin="0,0,4,0"
                            ToolTip="Exportar sesión JSON"
                            Click="Export_Click"/>
                    <Button x:Name="ClearButton"
                            Style="{StaticResource IconButton}"
                            Content="🗑"
                            FontSize="13"
                            Padding="6,3"
                            ToolTip="Limpiar lista"
                            Click="Clear_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
