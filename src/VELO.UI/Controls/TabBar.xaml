<UserControl x:Class="VELO.UI.Controls.TabBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:VELO.UI.Converters"
             Height="36">

    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrush"/>
    </UserControl.Resources>

    <Border Background="{StaticResource BackgroundMidBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,0,0,1">
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Stretch">

                <!-- Tab list -->
                <ItemsControl x:Name="TabList"
                              VerticalAlignment="Stretch">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Stretch"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border MinWidth="120" MaxWidth="200"
                                    BorderThickness="0,0,0,3"
                                    BorderBrush="{Binding ContainerColor, Converter={StaticResource StringToBrush}}"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="Tab_Click"
                                    MouseRightButtonDown="Tab_RightClick"
                                    Tag="{Binding Id}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource BackgroundMidBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource BackgroundLightBrush}"/>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource BackgroundHoverBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid Margin="8,0,4,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Title}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               FontSize="12">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Button Grid.Column="1"
                                            Style="{StaticResource IconButton}"
                                            Content="✕"
                                            FontSize="10"
                                            Padding="4"
                                            VerticalAlignment="Center"
                                            Click="CloseTab_Click"
                                            Tag="{Binding Id}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- New tab button — right next to the last tab -->
                <Button x:Name="NewTabBtn"
                        Style="{StaticResource IconButton}"
                        Content="+"
                        FontSize="14"
                        Padding="10,0"
                        VerticalAlignment="Center"
                        Click="NewTab_Click"/>

            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
