<UserControl x:Class="VELO.UI.Controls.CommandBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Collapsed"
             AutomationProperties.Name="Paleta de comandos">

    <!-- Full-overlay backdrop — click outside to dismiss -->
    <Grid Background="#99000000"
          MouseLeftButtonDown="Backdrop_Click">

        <!-- Palette popup — centred, fixed width, auto height -->
        <Border x:Name="PaletteBox"
                Width="540"
                MaxHeight="440"
                VerticalAlignment="Top"
                Margin="0,80,0,0"
                HorizontalAlignment="Center"
                Background="#FF0F0F1E"
                BorderBrush="#FF3A3A5A"
                BorderThickness="1"
                CornerRadius="8">

            <!-- Prevent backdrop click from reaching through the popup -->
            <Border.Effect>
                <DropShadowEffect BlurRadius="32" ShadowDepth="0"
                                  Color="#000000" Opacity="0.7"/>
            </Border.Effect>
            <Border MouseLeftButtonDown="Palette_StopBubble">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Search input -->
                        <RowDefinition Height="Auto"/>  <!-- Separator -->
                        <RowDefinition Height="*"/>     <!-- Results list -->
                    </Grid.RowDefinitions>

                    <!-- ── Search input ───────────────────────────────── -->
                    <Grid Grid.Row="0" Margin="14,12,14,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="⌕"
                                   FontSize="18"
                                   Foreground="#FF5555AA"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <TextBox x:Name="SearchBox"
                                 Grid.Column="1"
                                 Background="Transparent"
                                 Foreground="#FFE0E0FF"
                                 CaretBrush="#FFE0E0FF"
                                 BorderThickness="0"
                                 FontSize="15"
                                 VerticalAlignment="Center"
                                 KeyDown="SearchBox_KeyDown"
                                 TextChanged="SearchBox_TextChanged"/>
                        <TextBlock x:Name="PlaceholderText"
                                   Grid.Column="1"
                                   Text="Buscar pestañas, comandos, historial…"
                                   FontSize="15"
                                   Foreground="#FF444466"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"/>
                    </Grid>

                    <!-- Separator -->
                    <Border Grid.Row="1"
                            Height="1"
                            Background="#FF2A2A3A"
                            Margin="0,0,0,4"/>

                    <!-- ── Results list ───────────────────────────────── -->
                    <ListBox x:Name="ResultsList"
                             Grid.Row="2"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             MaxHeight="340"
                             Margin="6,0,6,8"
                             KeyDown="ResultsList_KeyDown"
                             MouseDoubleClick="ResultsList_DoubleClick"
                             SelectionChanged="ResultsList_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,1"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemBorder"
                                                    Background="Transparent"
                                                    CornerRadius="5"
                                                    Padding="10,7">
                                                <ContentPresenter/>
                                                <VisualStateManager.VisualStateGroups>
                                                    <VisualStateGroup x:Name="SelectionStates">
                                                        <VisualState x:Name="Selected">
                                                            <Storyboard>
                                                                <ColorAnimation Storyboard.TargetName="ItemBorder"
                                                                                Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                                                To="#FF1E1E3A" Duration="0"/>
                                                            </Storyboard>
                                                        </VisualState>
                                                        <VisualState x:Name="Unselected"/>
                                                    </VisualStateGroup>
                                                    <VisualStateGroup x:Name="CommonStates">
                                                        <VisualState x:Name="MouseOver">
                                                            <Storyboard>
                                                                <ColorAnimation Storyboard.TargetName="ItemBorder"
                                                                                Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                                                To="#FF181830" Duration="0"/>
                                                            </Storyboard>
                                                        </VisualState>
                                                        <VisualState x:Name="Normal"/>
                                                    </VisualStateGroup>
                                                </VisualStateManager.VisualStateGroups>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>   <!-- Icon -->
                                        <ColumnDefinition Width="*"/>    <!-- Text -->
                                        <ColumnDefinition Width="Auto"/> <!-- Badge -->
                                    </Grid.ColumnDefinitions>

                                    <!-- Icon -->
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Icon}"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"/>

                                    <!-- Title + subtitle -->
                                    <StackPanel Grid.Column="1"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="13"
                                                   Foreground="#FFD0D0EE"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Subtitle}"
                                                   FontSize="11"
                                                   Foreground="#FF555577"
                                                   TextTrimming="CharacterEllipsis"
                                                   Visibility="{Binding HasSubtitle}"/>
                                    </StackPanel>

                                    <!-- Category badge -->
                                    <Border Grid.Column="2"
                                            Background="#FF1A1A2E"
                                            BorderBrush="#FF2A2A4A"
                                            BorderThickness="1"
                                            CornerRadius="3"
                                            Padding="5,1"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Badge}"
                                                   FontSize="10"
                                                   Foreground="#FF4444AA"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
