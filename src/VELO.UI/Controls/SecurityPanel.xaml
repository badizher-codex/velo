<UserControl x:Class="VELO.UI.Controls.SecurityPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="Auto"
             Visibility="Collapsed">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>   <!-- Mini tab -->
            <ColumnDefinition Width="Auto"/>   <!-- Full panel -->
        </Grid.ColumnDefinitions>

        <!-- ── Mini tab (collapsed state) ────────────────────────────── -->
        <Border x:Name="MiniTab"
                Grid.Column="0"
                Width="26"
                Background="#14142A"
                BorderBrush="{Binding ElementName=PanelBorder, Path=BorderBrush}"
                BorderThickness="2,0,0,0"
                Cursor="Hand"
                Visibility="Collapsed"
                MouseLeftButtonDown="MiniTab_Click"
                ToolTip="Ver amenazas detectadas">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Margin="0,12">
                <!-- Badge count -->
                <Border x:Name="MiniBadge"
                        CornerRadius="8" Width="18" Height="18"
                        Background="#FF3D71"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,6">
                    <TextBlock x:Name="MiniBadgeCount"
                               Text="1" FontSize="10" FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <!-- Rotated label -->
                <TextBlock x:Name="MiniLabel"
                           Text="AMENAZA"
                           FontSize="9" FontWeight="SemiBold"
                           Foreground="#FF3D71"
                           HorizontalAlignment="Center">
                    <TextBlock.LayoutTransform>
                        <RotateTransform Angle="90"/>
                    </TextBlock.LayoutTransform>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── Full panel ─────────────────────────────────────────────── -->
        <Border x:Name="PanelBorder"
                Grid.Column="1"
                Width="310"
                Background="{StaticResource BackgroundLightBrush}"
                BorderBrush="#FF3D71"
                BorderThickness="2,0,0,0"
                Padding="14"
                Visibility="Collapsed">
            <StackPanel>
                <!-- Header -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="VerdictIcon" Grid.Column="0"
                               FontSize="18" VerticalAlignment="Center"
                               Margin="0,0,6,0" Text="🔴"/>
                    <TextBlock x:Name="VerdictLabel" Grid.Column="1"
                               FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="#FF3D71"
                               Text="BLOQUEADO"/>
                    <!-- Collapse to mini -->
                    <Button Grid.Column="2"
                            Style="{StaticResource IconButton}"
                            Content="⟩" FontSize="13"
                            ToolTip="Minimizar"
                            Click="CollapseToMini_Click"/>
                    <!-- Close fully -->
                    <Button Grid.Column="3"
                            Style="{StaticResource IconButton}"
                            Content="✕" FontSize="11"
                            ToolTip="Cerrar"
                            Click="ClosePanel_Click"/>
                </Grid>

                <!-- Domain -->
                <TextBlock x:Name="DomainLabel"
                           FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"
                           Text="dominio.ejemplo.com"/>

                <!-- Reason -->
                <TextBlock Text="POR QUÉ:" FontSize="10"
                           Foreground="{StaticResource TextMutedBrush}"
                           Margin="0,0,0,3"/>
                <TextBlock x:Name="ReasonLabel"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"
                           Text="Explicación de la amenaza."/>

                <!-- Metadata -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Tipo:" Foreground="{StaticResource TextMutedBrush}" FontSize="10" Margin="0,2"/>
                    <TextBlock x:Name="ThreatTypeLabel" Grid.Row="0" Grid.Column="1" FontSize="10" Margin="8,2"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Confianza:" Foreground="{StaticResource TextMutedBrush}" FontSize="10" Margin="0,2"/>
                    <TextBlock x:Name="ConfidenceLabel" Grid.Row="1" Grid.Column="1" FontSize="10" Margin="8,2"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Fuente:" Foreground="{StaticResource TextMutedBrush}" FontSize="10" Margin="0,2"/>
                    <TextBlock x:Name="SourceLabel" Grid.Row="2" Grid.Column="1" FontSize="10" Margin="8,2"/>
                </Grid>

                <Separator/>

                <!-- Actions -->
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Button x:Name="AllowOnceButton"
                            Content="Permitir una vez"
                            FontSize="11" Padding="8,4" Margin="0,0,6,0"
                            Click="AllowOnce_Click"/>
                    <Button x:Name="WhitelistButton"
                            Content="Whitelist"
                            FontSize="11" Padding="8,4"
                            Click="Whitelist_Click"/>
                </StackPanel>

                <!-- Auto-close countdown -->
                <TextBlock x:Name="CountdownLabel"
                           FontSize="9" Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Right"
                           Margin="0,6,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
