<UserControl x:Class="VELO.UI.Controls.UrlBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="2"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Background="#FF111118"
                BorderBrush="#FF2A2A3A"
                BorderThickness="0,0,0,1"
                Padding="4,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>   <!-- Back -->
                    <ColumnDefinition Width="Auto"/>   <!-- Forward -->
                    <ColumnDefinition Width="Auto"/>   <!-- Reload/Stop -->
                    <ColumnDefinition Width="*"/>      <!-- URL pill -->
                    <ColumnDefinition Width="Auto"/>   <!-- AI mode indicator -->
                    <ColumnDefinition Width="Auto"/>   <!-- Container indicator -->
                    <ColumnDefinition Width="Auto"/>   <!-- Menu -->
                </Grid.ColumnDefinitions>

                <Button x:Name="BackButton" Grid.Column="0"
                        Style="{StaticResource IconButton}"
                        Content="←" FontSize="16"
                        Click="BackButton_Click"
                        IsEnabled="False"
                        ToolTip="Atrás"/>

                <Button x:Name="ForwardButton" Grid.Column="1"
                        Style="{StaticResource IconButton}"
                        Content="→" FontSize="16"
                        Click="ForwardButton_Click"
                        IsEnabled="False"
                        ToolTip="Adelante"/>

                <Button x:Name="ReloadButton" Grid.Column="2"
                        Style="{StaticResource IconButton}"
                        Content="↻" FontSize="16"
                        Click="ReloadButton_Click"
                        ToolTip="Recargar"/>

                <!-- URL pill: TLS + field + bookmark + zoom -->
                <Border Grid.Column="3"
                        Background="#FF1E1E2E"
                        BorderBrush="#FF3A3A55"
                        BorderThickness="1"
                        CornerRadius="8"
                        Margin="6,5,6,5"
                        Padding="4,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>   <!-- TLS -->
                            <ColumnDefinition Width="*"/>      <!-- URL field -->
                            <ColumnDefinition Width="Auto"/>   <!-- Zoom -->
                            <ColumnDefinition Width="Auto"/>   <!-- Reader mode -->
                            <ColumnDefinition Width="Auto"/>   <!-- Bookmark -->
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="TlsIndicator" Grid.Column="0"
                                   Text="🔒" FontSize="13"
                                   VerticalAlignment="Center"
                                   Margin="4,0,2,0"
                                   ToolTip="Conexión segura"/>

                        <TextBox x:Name="UrlField" Grid.Column="1"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 VerticalAlignment="Center"
                                 FontSize="13"
                                 Foreground="#FFD0D0E8"
                                 CaretBrush="#FF00E5FF"
                                 Padding="4,0"
                                 KeyDown="UrlField_KeyDown"
                                 GotFocus="UrlField_GotFocus"
                                 LostFocus="UrlField_LostFocus"/>

                        <!-- Zoom indicator — hidden at 100% -->
                        <Button x:Name="ZoomIndicator" Grid.Column="2"
                                Style="{StaticResource IconButton}"
                                FontSize="11" Padding="6,4"
                                Visibility="Collapsed"
                                Click="ZoomReset_Click"
                                ToolTip="Restablecer zoom (Ctrl+0)"/>

                        <Button x:Name="ReaderModeButton" Grid.Column="3"
                                Style="{StaticResource IconButton}"
                                Content="📖" FontSize="13"
                                Visibility="Collapsed"
                                Click="ReaderModeButton_Click"
                                ToolTip="Modo Lector (F9)"/>

                        <Button x:Name="BookmarkButton" Grid.Column="4"
                                Style="{StaticResource IconButton}"
                                Content="☆" FontSize="15"
                                Click="BookmarkButton_Click"
                                ToolTip="Guardar marcador"/>
                    </Grid>
                </Border>

                <!-- AI status indicator: dot + label -->
                <StackPanel Grid.Column="4" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="2,0,6,0"
                            Cursor="Hand">
                    <StackPanel.ToolTip>
                        <ToolTip x:Name="AiTooltip" Content="IA: Offline (sin modelo)"/>
                    </StackPanel.ToolTip>
                    <Ellipse x:Name="AiDot"
                             Width="8" Height="8"
                             VerticalAlignment="Center"
                             Margin="0,0,4,0"
                             Fill="#555566"/>
                    <TextBlock x:Name="AiLabel"
                               Text="IA" FontSize="11" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="#555566"/>
                </StackPanel>

                <Ellipse x:Name="ContainerIndicator" Grid.Column="5"
                         Width="10" Height="10"
                         Margin="2,0,4,0"
                         VerticalAlignment="Center"
                         Visibility="Collapsed"/>

                <Button x:Name="MenuButton" Grid.Column="6"
                        Style="{StaticResource IconButton}"
                        Content="⋮" FontSize="18"
                        Click="MenuButton_Click"
                        ToolTip="Menú"/>
            </Grid>
        </Border>

        <!-- Loading bar (2px sweep animation at bottom of toolbar) -->
        <Canvas x:Name="LoadingCanvas" Grid.Row="1"
                ClipToBounds="True"
                Visibility="Collapsed">
            <Rectangle x:Name="LoadingRect" Height="2" Width="160">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent"  Offset="0"/>
                        <GradientStop Color="#00E5FF"      Offset="0.3"/>
                        <GradientStop Color="#80E5FF"      Offset="0.5"/>
                        <GradientStop Color="#00E5FF"      Offset="0.7"/>
                        <GradientStop Color="Transparent"  Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Canvas>
    </Grid>
</UserControl>
