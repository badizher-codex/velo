<UserControl x:Class="VELO.UI.Controls.UrlBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:VELO.UI.Controls">

    <UserControl.Resources>
        <!-- v2.4.37 — vector nav icons.
             Stroke-only paths (no Fill) drawn in a 24x24 SVG-like viewBox
             then Viewbox-scaled to 14px. Independent of any system icon
             font; same look on every Windows version. Geometry inspired
             by Lucide (MIT). -->
        <Style x:Key="NavIconPath" TargetType="Path">
            <Setter Property="Stroke"             Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="StrokeThickness"    Value="2"/>
            <Setter Property="StrokeLineJoin"     Value="Round"/>
            <Setter Property="StrokeStartLineCap" Value="Round"/>
            <Setter Property="StrokeEndLineCap"   Value="Round"/>
            <Setter Property="Fill"               Value="Transparent"/>
        </Style>
    </UserControl.Resources>

    <!-- Phase 5.2 re-skin — frame 1 URL row. Layout / functions preserved. -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="2"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceDarkBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1"
                Padding="4,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>   <!-- Shield Score -->
                    <ColumnDefinition Width="Auto"/>   <!-- Back -->
                    <ColumnDefinition Width="Auto"/>   <!-- Forward -->
                    <ColumnDefinition Width="Auto"/>   <!-- Reload/Stop -->
                    <ColumnDefinition Width="*"/>      <!-- URL pill -->
                    <ColumnDefinition Width="Auto"/>   <!-- AI mode indicator -->
                    <ColumnDefinition Width="Auto"/>   <!-- Container indicator -->
                    <ColumnDefinition Width="Auto"/>   <!-- Menu -->
                </Grid.ColumnDefinitions>

                <controls:ShieldScoreControl x:Name="ShieldBadge" Grid.Column="0"
                        Margin="2,0,0,0"
                        VerticalAlignment="Center"
                        AutomationProperties.Name="Shield Score"
                        ShieldClicked="ShieldBadge_Click"/>

                <!-- v2.4.37: nav icons are pure WPF Path geometry inside a
                     Viewbox. No system font dependency, identical render on
                     every Windows version. Geometry inspired by Lucide (MIT). -->
                <Button x:Name="BackButton" Grid.Column="1"
                        Style="{StaticResource IconButton}"
                        Click="BackButton_Click"
                        IsEnabled="False"
                        ToolTip="Atrás">
                    <Viewbox Width="14" Height="14" Stretch="Uniform">
                        <Canvas Width="24" Height="24">
                            <Path
                                Style="{StaticResource NavIconPath}"
                                Data="M 15,6 L 9,12 L 15,18"/>
                        </Canvas>
                    </Viewbox>
                </Button>

                <Button x:Name="ForwardButton" Grid.Column="2"
                        Style="{StaticResource IconButton}"
                        Click="ForwardButton_Click"
                        IsEnabled="False"
                        ToolTip="Adelante">
                    <Viewbox Width="14" Height="14" Stretch="Uniform">
                        <Canvas Width="24" Height="24">
                            <Path
                                Style="{StaticResource NavIconPath}"
                                Data="M 9,6 L 15,12 L 9,18"/>
                        </Canvas>
                    </Viewbox>
                </Button>

                <Button x:Name="ReloadButton" Grid.Column="3"
                        Style="{StaticResource IconButton}"
                        Click="ReloadButton_Click"
                        ToolTip="Recargar">
                    <Grid>
                        <Viewbox x:Name="ReloadIcon" Width="15" Height="15" Stretch="Uniform">
                            <Canvas Width="24" Height="24">
                                <!-- Circular arrow (refresh). 3/4 arc CCW + arrow corner. -->
                                <Path
                                    Style="{StaticResource NavIconPath}"
                                    Data="M 20,12 A 8,8 0 1 1 6.5,6 L 4,8 M 4,4 L 4,8 L 8,8"/>
                            </Canvas>
                        </Viewbox>
                        <Viewbox x:Name="StopIcon" Width="13" Height="13" Stretch="Uniform"
                                 Visibility="Collapsed">
                            <Canvas Width="24" Height="24">
                                <!-- Cancel X -->
                                <Path
                                    Style="{StaticResource NavIconPath}"
                                    Data="M 6,6 L 18,18 M 6,18 L 18,6"/>
                            </Canvas>
                        </Viewbox>
                    </Grid>
                </Button>

                <!-- URL pill: TLS + field + bookmark + zoom.
                     v2.4.37 — soft purple focus ring when keyboard focus
                     is inside the pill (typing in UrlField). -->
                <Border Grid.Column="4"
                        Background="{StaticResource SurfaceMidBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Margin="6,5,6,5"
                        Padding="4,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="{StaticResource BorderEmphasisBrush}"/>
                            <Style.Triggers>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentPurpleBrush}"/>
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Color="#7C5CFF"
                                                              Opacity="0.45"
                                                              BlurRadius="14"
                                                              ShadowDepth="0"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>   <!-- TLS -->
                            <ColumnDefinition Width="*"/>      <!-- URL field -->
                            <ColumnDefinition Width="Auto"/>   <!-- Zoom -->
                            <ColumnDefinition Width="Auto"/>   <!-- TL;DR badge (v2.4.12) -->
                            <ColumnDefinition Width="Auto"/>   <!-- Reader mode -->
                            <ColumnDefinition Width="Auto"/>   <!-- Bookmark -->
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="TlsIndicator" Grid.Column="0"
                                   Text="🔒" FontSize="13"
                                   VerticalAlignment="Center"
                                   Margin="4,0,2,0"
                                   ToolTip="Conexión segura"/>

                        <TextBox x:Name="UrlField" Grid.Column="1"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 VerticalAlignment="Center"
                                 FontSize="13"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 CaretBrush="{StaticResource AccentPurpleBrush}"
                                 SelectionBrush="{StaticResource AccentPurpleBrush}"
                                 Padding="4,0"
                                 KeyDown="UrlField_KeyDown"
                                 GotFocus="UrlField_GotFocus"
                                 LostFocus="UrlField_LostFocus"/>

                        <!-- Zoom indicator — hidden at 100% -->
                        <Button x:Name="ZoomIndicator" Grid.Column="2"
                                Style="{StaticResource IconButton}"
                                FontSize="11" Padding="6,4"
                                Visibility="Collapsed"
                                Click="ZoomReset_Click"/>

                        <!-- TL;DR badge (Sprint 9C, wired in v2.4.12). Visible only on
                             pages eligible per TldrService.IsEligible (>600 words,
                             non-login URL). Click → spawns AI summary modal.
                             v2.4.34 — adopts the BadgeBlue token pair from Phase 5.0. -->
                        <Button x:Name="TldrBadge" Grid.Column="3"
                                FontSize="11" Padding="7,3"
                                Background="{StaticResource BadgeBlueBgBrush}"
                                Foreground="{StaticResource BadgeBlueBrush}"
                                BorderBrush="{StaticResource BadgeBlueBrush}"
                                BorderThickness="1"
                                Margin="2,0,4,0" Cursor="Hand"
                                Visibility="Collapsed"
                                Click="TldrBadge_Click"
                                ToolTip="Resumen TL;DR de esta página">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                            <TextBlock Text="📄 TL;DR" FontWeight="SemiBold"/>
                        </Button>

                        <Button x:Name="ReaderModeButton" Grid.Column="4"
                                Style="{StaticResource IconButton}"
                                Content="📖" FontSize="13"
                                Visibility="Collapsed"
                                Click="ReaderModeButton_Click"
                                ToolTip="Modo Lector (F9)"/>

                        <Button x:Name="BookmarkButton" Grid.Column="5"
                                Style="{StaticResource IconButton}"
                                Content="☆" FontSize="15"
                                Click="BookmarkButton_Click"
                                ToolTip="Guardar marcador"/>
                    </Grid>
                </Border>

                <!-- AI status indicator: robot + dot + label — click opens VeloAgent chat -->
                <StackPanel x:Name="AiIndicatorPanel"
                            Grid.Column="5" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="2,0,6,0"
                            Cursor="Hand"
                            MouseLeftButtonDown="AiIndicator_Click">
                    <StackPanel.ToolTip>
                        <ToolTip x:Name="AiTooltip" Content="IA: Offline (sin modelo)"/>
                    </StackPanel.ToolTip>
                    <TextBlock x:Name="AiRobot"
                               Text="🤖" FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,3,0"
                               Opacity="0.7"/>
                    <!-- AiDot Fill set dynamically by code-behind based on adapter state;
                         default is the muted grey for "no model loaded". -->
                    <Ellipse x:Name="AiDot"
                             Width="8" Height="8"
                             VerticalAlignment="Center"
                             Margin="0,0,4,0"
                             Fill="#555566"/>
                    <TextBlock x:Name="AiLabel"
                               Text="IA" FontSize="11" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextMutedBrush}"/>
                </StackPanel>

                <Ellipse x:Name="ContainerIndicator" Grid.Column="6"
                         Width="10" Height="10"
                         Margin="2,0,4,0"
                         VerticalAlignment="Center"
                         Visibility="Collapsed"/>

                <Button x:Name="MenuButton" Grid.Column="7"
                        Style="{StaticResource IconButton}"
                        Click="MenuButton_Click"
                        ToolTip="Menú">
                    <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Ellipse Width="3" Height="3" Fill="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                        <Ellipse Width="3" Height="3" Fill="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                        <Ellipse Width="3" Height="3" Fill="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Loading bar (2px sweep animation at bottom of toolbar) — purple sweep. -->
        <Canvas x:Name="LoadingCanvas" Grid.Row="1"
                ClipToBounds="True"
                Visibility="Collapsed">
            <Rectangle x:Name="LoadingRect" Height="2" Width="180">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent"  Offset="0"/>
                        <GradientStop Color="#7C5CFF"      Offset="0.3"/>
                        <GradientStop Color="#A48BFF"      Offset="0.5"/>
                        <GradientStop Color="#7C5CFF"      Offset="0.7"/>
                        <GradientStop Color="Transparent"  Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Canvas>
    </Grid>
</UserControl>
