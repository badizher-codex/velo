<UserControl x:Class="VELO.UI.Controls.AutofillToast"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="340"
             Visibility="Collapsed"
             Opacity="0"
             AutomationProperties.Name="Autofill prompt">

    <Border Background="#FF111118"
            BorderBrush="#FF3A6CD8"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14,12"
            Effect="{StaticResource DropShadowEffect}">

        <StackPanel>
            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="🔑" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="TitleLabel"
                           Text="Use saved password?"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#FFE0E0F0"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Username / domain -->
            <TextBlock x:Name="DetailLabel"
                       Text="user@example.com — example.com"
                       FontSize="12"
                       Foreground="#FFA0A0B0"
                       Margin="22,0,0,8"
                       TextTrimming="CharacterEllipsis"/>

            <!-- Optional breach warning -->
            <Border x:Name="BreachBanner"
                    Background="#1AE53E3E"
                    BorderBrush="#FFE53E3E"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8,5"
                    Margin="22,0,0,8"
                    Visibility="Collapsed">
                <TextBlock x:Name="BreachLabel"
                           Text="⚠ This password appears in known breaches."
                           FontSize="11"
                           Foreground="#FFE53E3E"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- Action buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                <Button x:Name="DismissButton"
                        Content="Dismiss"
                        Click="OnDismissClick"
                        Background="Transparent"
                        Foreground="#FFA0A0B0"
                        BorderBrush="#FF333344"
                        BorderThickness="1"
                        Padding="12,4"
                        Margin="0,0,8,0"
                        Cursor="Hand"/>
                <Button x:Name="PrimaryButton"
                        Content="Use"
                        Click="OnPrimaryClick"
                        Background="#FF3A6CD8"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="14,4"
                        Cursor="Hand"
                        FontWeight="SemiBold"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
