<UserControl x:Class="VELO.UI.Controls.AutofillToast"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="360"
             Visibility="Collapsed"
             Opacity="0"
             AutomationProperties.Name="Autofill prompt">

    <!-- Phase 5.2 re-skin — purple accent. -->
    <Border Background="{StaticResource SurfaceDarkBrush}"
            BorderBrush="{StaticResource AccentPurpleBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="16,14"
            Effect="{StaticResource DropShadowEffect}">

        <StackPanel>
            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="🔑" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="TitleLabel"
                           Text="Use saved password?"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Username / domain -->
            <TextBlock x:Name="DetailLabel"
                       Text="user@example.com — example.com"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="22,0,0,10"
                       TextTrimming="CharacterEllipsis"/>

            <!-- Optional breach warning -->
            <Border x:Name="BreachBanner"
                    Style="{StaticResource StatusPill}"
                    Background="{StaticResource BadgeRedBgBrush}"
                    BorderBrush="{StaticResource BadgeRedBrush}"
                    BorderThickness="1"
                    HorizontalAlignment="Stretch"
                    Padding="10,6"
                    CornerRadius="8"
                    Margin="22,0,0,10"
                    Visibility="Collapsed">
                <TextBlock x:Name="BreachLabel"
                           Text="⚠ This password appears in known breaches."
                           FontSize="11"
                           Foreground="{StaticResource BadgeRedBrush}"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- Action buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                <Button x:Name="DismissButton"
                        Content="Dismiss"
                        Click="OnDismissClick"
                        Style="{StaticResource GhostButton}"
                        Padding="14,5"
                        FontSize="12"
                        Margin="0,0,8,0"/>
                <!-- x:Name is "PrimaryButton" by historical contract; Style key
                     "PrimaryButton" applies the new purple-gradient CTA. -->
                <Button x:Name="PrimaryButton"
                        Content="Use"
                        Click="OnPrimaryClick"
                        Style="{StaticResource PrimaryButton}"
                        Padding="18,5"
                        FontSize="12"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
