<UserControl x:Class="VELO.UI.Controls.VeloAgentPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="340"
             MinWidth="300"
             MaxWidth="520"
             Visibility="Collapsed"
             AutomationProperties.Name="VeloAgent — Asistente de privacidad">

    <!-- Phase 5.2 re-skin — frames 1 + 2. Layout/contract unchanged. -->
    <Border Background="{StaticResource BackgroundDarkestBrush}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="1,0,0,0">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Header -->
                <RowDefinition Height="*"/>      <!-- Message list -->
                <RowDefinition Height="Auto"/>   <!-- Typing indicator -->
                <RowDefinition Height="Auto"/>   <!-- Input area -->
            </Grid.RowDefinitions>

            <!-- ── Header ───────────────────────────────────────────────── -->
            <Border Grid.Row="0"
                    Background="{StaticResource SurfaceDarkBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="14,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🤖" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <StackPanel>
                            <TextBlock Text="VeloAgent"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="BackendLabel"
                                       Text="Sin modelo"
                                       FontSize="10"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="AskAboutPageButton"
                                Content="💬" FontSize="13"
                                Style="{StaticResource IconButton}"
                                ToolTip="Preguntar sobre esta página"
                                Click="AskAboutPage_Click"/>
                        <Button x:Name="ClearButton"
                                Content="🗑" FontSize="13"
                                Style="{StaticResource IconButton}"
                                ToolTip="Limpiar conversación"
                                Click="Clear_Click"/>
                        <Button x:Name="CloseButton"
                                Content="✕" FontSize="13"
                                Style="{StaticResource IconButton}"
                                ToolTip="Cerrar panel (Ctrl+Shift+A)"
                                Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Message list ──────────────────────────────────────────── -->
            <ScrollViewer x:Name="MessagesScroll"
                          Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="0,4">
                <StackPanel x:Name="MessagesPanel"
                            Margin="0,4"
                            CanHorizontallyScroll="False"/>
            </ScrollViewer>

            <!-- ── Typing indicator ──────────────────────────────────────── -->
            <Border x:Name="TypingIndicator"
                    Grid.Row="2"
                    Visibility="Collapsed"
                    Padding="14,7">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="VeloAgent está pensando"
                               FontSize="11" FontStyle="Italic"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="TypingDots"
                               Text="…"
                               FontSize="11"
                               Foreground="{StaticResource AccentPurpleLightBrush}"
                               VerticalAlignment="Center"
                               Margin="2,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- ── Input area ────────────────────────────────────────────── -->
            <Border Grid.Row="3"
                    Background="{StaticResource SurfaceDarkBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="{StaticResource SurfaceLightBrush}"
                            BorderBrush="{StaticResource BorderEmphasisBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10,7">
                        <TextBox x:Name="InputBox"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 CaretBrush="{StaticResource AccentPurpleBrush}"
                                 SelectionBrush="{StaticResource AccentPurpleBrush}"
                                 FontSize="13"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="False"
                                 MaxHeight="80"
                                 VerticalScrollBarVisibility="Auto"
                                 KeyDown="Input_KeyDown"
                                 AutomationProperties.Name="Mensaje para VeloAgent"
                                 ToolTip="Escribe un mensaje — Enter para enviar"/>
                    </Border>

                    <Button x:Name="SendButton"
                            Grid.Column="1"
                            Content="↑"
                            FontSize="18"
                            Width="38" Height="38"
                            Margin="8,0,0,0"
                            Background="{StaticResource AccentPurpleGradientBrush}"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="Bold"
                            Cursor="Hand"
                            VerticalAlignment="Bottom"
                            AutomationProperties.Name="Enviar mensaje"
                            Click="Send_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="19"
                                                    Width="{TemplateBinding Width}"
                                                    Height="{TemplateBinding Height}">
                                                <Border.Effect>
                                                    <DropShadowEffect Color="#7C5CFF" Opacity="0.35"
                                                                      BlurRadius="14" ShadowDepth="0"/>
                                                </Border.Effect>
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.75"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
