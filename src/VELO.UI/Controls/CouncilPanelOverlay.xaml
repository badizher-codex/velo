<UserControl x:Class="VELO.UI.Controls.CouncilPanelOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Collapsed"
             AutomationProperties.Name="Council panel capture toolbar"
             d:DesignHeight="36" d:DesignWidth="280"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <!-- Phase 4.1 chunk F (v2.4.47) — Per-panel mini-toolbar that floats
         over each cell of the 2×2 Council layout. Hosts the four capture
         buttons (Text / Code / Table / Citation) the user clicks to
         attach fragments of the panel's reply to the next synthesis.
         The provider chip on the left makes it obvious which slot the
         toolbar belongs to (Claude / ChatGpt / Grok / Local).

         Inert in this release — no host instantiates it yet; chunk G
         brings it up alongside the 2×2 layout. Visibility=Collapsed by
         default so a stray instance can't break the UI. -->

    <Border Background="{StaticResource SurfaceMidBrush}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="6,4"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,8,8,0"
            Opacity="0.95">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.30"/>
        </Border.Effect>

        <StackPanel Orientation="Horizontal">

            <!-- Provider chip — set via SetProvider(...) in code-behind. -->
            <Border x:Name="ProviderChip"
                    CornerRadius="6"
                    Background="{StaticResource AccentPurpleLightBrush}"
                    Padding="6,2"
                    Margin="0,0,6,0"
                    VerticalAlignment="Center">
                <TextBlock x:Name="ProviderLabel"
                           Text="Provider"
                           FontSize="10.5"
                           FontWeight="SemiBold"
                           Foreground="#FFFFFFFF"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- Capture-Text -->
            <Button x:Name="CaptureTextButton"
                    Style="{StaticResource GhostButton}"
                    Padding="6,2"
                    Margin="0,0,2,0"
                    FontSize="11"
                    Click="OnCaptureTextClick"
                    ToolTip="Capturar texto del último mensaje del panel">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📝" Margin="0,0,4,0"/>
                    <TextBlock Text="Texto" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Capture-Code -->
            <Button x:Name="CaptureCodeButton"
                    Style="{StaticResource GhostButton}"
                    Padding="6,2"
                    Margin="0,0,2,0"
                    FontSize="11"
                    Click="OnCaptureCodeClick"
                    ToolTip="Capturar bloques de código del último mensaje">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="💻" Margin="0,0,4,0"/>
                    <TextBlock Text="Código" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Capture-Table -->
            <Button x:Name="CaptureTableButton"
                    Style="{StaticResource GhostButton}"
                    Padding="6,2"
                    Margin="0,0,2,0"
                    FontSize="11"
                    Click="OnCaptureTableClick"
                    ToolTip="Capturar tabla del último mensaje">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📊" Margin="0,0,4,0"/>
                    <TextBlock Text="Tabla" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Capture-Citation -->
            <Button x:Name="CaptureCitationButton"
                    Style="{StaticResource GhostButton}"
                    Padding="6,2"
                    FontSize="11"
                    Click="OnCaptureCitationClick"
                    ToolTip="Capturar citas / enlaces del último mensaje">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔗" Margin="0,0,4,0"/>
                    <TextBlock Text="Cita" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Border>
</UserControl>
