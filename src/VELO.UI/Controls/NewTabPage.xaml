<UserControl x:Class="VELO.UI.Controls.NewTabPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundDarkestBrush}">

    <!-- Phase 5.2 re-skin — frame 1 NewTab area. Layout preserved. -->
    <Grid>
        <!-- Background image — centered, faded -->
        <Image Source="pack://application:,,,/VELO.UI;component/Assets/velo-logo.png"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               MaxHeight="500"
               Opacity="0.08"
               RenderOptions.BitmapScalingMode="HighQuality"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>         <!-- top spacer -->
                    <RowDefinition Height="Auto"/>      <!-- logo + clock -->
                    <RowDefinition Height="Auto"/>      <!-- search bar -->
                    <RowDefinition Height="Auto"/>      <!-- top sites -->
                    <RowDefinition Height="Auto"/>      <!-- privacy stats -->
                    <RowDefinition Height="*"/>         <!-- bottom spacer -->
                </Grid.RowDefinitions>

                <!-- Top spacer -->
                <FrameworkElement Grid.Row="0" MinHeight="60"/>

                <!-- Logo + Clock -->
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,30">
                    <TextBlock x:Name="LogoText"
                               Text="VELO"
                               FontSize="54"
                               FontWeight="SemiBold"
                               FontFamily="Segoe UI"
                               Foreground="{StaticResource AccentPurpleLightBrush}"
                               HorizontalAlignment="Center"
                               AutomationProperties.Name="VELO Browser"/>
                    <TextBlock x:Name="ClockText"
                               FontSize="20"
                               FontWeight="Light"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Search bar -->
                <Border Grid.Row="2" MaxWidth="600"
                        Background="{StaticResource SurfaceLightBrush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}"
                        BorderThickness="1"
                        CornerRadius="28"
                        Padding="18,0"
                        Margin="0,0,0,30">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🔍" FontSize="16"
                                   VerticalAlignment="Center" Margin="0,0,10,0"
                                   Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBox x:Name="SearchBox"
                                 Grid.Column="1"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 CaretBrush="{StaticResource AccentPurpleBrush}"
                                 SelectionBrush="{StaticResource AccentPurpleBrush}"
                                 FontSize="14"
                                 Padding="0,14"
                                 VerticalAlignment="Center"
                                 KeyDown="SearchBox_KeyDown"
                                 AutomationProperties.Name="Busca o escribe una URL"
                                 Text=""/>
                    </Grid>
                </Border>

                <!-- Top sites section -->
                <StackPanel Grid.Row="3" HorizontalAlignment="Center" Margin="0,0,0,22">

                    <!-- Tiles row 1 -->
                    <StackPanel x:Name="TopSitesRow1" Orientation="Horizontal"
                                HorizontalAlignment="Center" Margin="0,0,0,10"/>

                    <!-- Tiles row 2 -->
                    <StackPanel x:Name="TopSitesRow2" Orientation="Horizontal"
                                HorizontalAlignment="Center"/>

                    <!-- Empty state -->
                    <TextBlock x:Name="EmptyState"
                               Text="Aquí aparecerán tus sitios más visitados"
                               FontSize="12.5"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,0"
                               Visibility="Collapsed"/>
                </StackPanel>

                <!-- Privacy stats bar — card-styled -->
                <Border Grid.Row="4"
                        Style="{StaticResource Card}"
                        MaxWidth="600"
                        Padding="20,12"
                        Margin="0,0,0,28"
                        HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🛡 " FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatsText"
                                   FontSize="12.5"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   Text="Cargando estadísticas…"/>
                    </StackPanel>
                </Border>

                <!-- Bottom spacer -->
                <FrameworkElement Grid.Row="5" MinHeight="40"/>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
