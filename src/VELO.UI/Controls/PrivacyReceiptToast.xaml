<UserControl x:Class="VELO.UI.Controls.PrivacyReceiptToast"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="300"
             Visibility="Collapsed"
             Opacity="0"
             IsHitTestVisible="False"
             AutomationProperties.Name="Privacy Receipt"
             AutomationProperties.HelpText="Resumen de privacidad de la pestaña cerrada">

    <Border Background="#FF111118"
            BorderBrush="#FF2EB54F"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12,10"
            Effect="{StaticResource DropShadowEffect}">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                <TextBlock Text="🛡" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock x:Name="DomainLabel"
                           Text="ejemplo.com"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#FFD0D0E8"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Grid.Row="0" Grid.Column="1"
                       Text="Privacy Receipt"
                       FontSize="10"
                       Foreground="#FF888899"
                       VerticalAlignment="Center"/>

            <!-- Stats row -->
            <StackPanel Grid.Row="1" Grid.ColumnSpan="2"
                        Orientation="Horizontal"
                        Margin="0,6,0,4">

                <Border Background="#1A2EB54F" CornerRadius="4" Padding="6,3" Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="TrackerCount" Text="0"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="#FF2EB54F"/>
                        <TextBlock Text=" rastreadores" FontSize="11" Foreground="#FF888899"
                                   VerticalAlignment="Bottom"/>
                    </StackPanel>
                </Border>

                <Border Background="#1AF0B429" CornerRadius="4" Padding="6,3" Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="AdCount" Text="0"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="#FFF0B429"/>
                        <TextBlock Text=" anuncios" FontSize="11" Foreground="#FF888899"
                                   VerticalAlignment="Bottom"/>
                    </StackPanel>
                </Border>

                <Border Background="#1AE53E3E" CornerRadius="4" Padding="6,3">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="FingerprintCount" Text="0"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="#FFE53E3E"/>
                        <TextBlock Text=" fingerprint" FontSize="11" Foreground="#FF888899"
                                   VerticalAlignment="Bottom"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Footer hint -->
            <TextBlock Grid.Row="2" Grid.ColumnSpan="2"
                       x:Name="FooterLabel"
                       Text="bloqueados en esta sesión"
                       FontSize="10"
                       Foreground="#FF555566"/>
        </Grid>
    </Border>
</UserControl>
