<UserControl x:Class="VELO.UI.Controls.PrivacyReceiptToast"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="320"
             Visibility="Collapsed"
             Opacity="0"
             IsHitTestVisible="False"
             AutomationProperties.Name="Privacy Receipt"
             AutomationProperties.HelpText="Resumen de privacidad de la pestaña cerrada">

    <!-- Phase 5.2 re-skin — green accent (session-closed privacy summary). -->
    <Border Background="{StaticResource SurfaceDarkBrush}"
            BorderBrush="{StaticResource BadgeGreenBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="14,12"
            Effect="{StaticResource DropShadowEffect}">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                <TextBlock Text="🛡" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock x:Name="DomainLabel"
                           Text="ejemplo.com"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Grid.Row="0" Grid.Column="1"
                       Text="Privacy Receipt"
                       FontSize="10"
                       Foreground="{StaticResource TextMutedBrush}"
                       VerticalAlignment="Center"/>

            <!-- Stats row -->
            <StackPanel Grid.Row="1" Grid.ColumnSpan="2"
                        Orientation="Horizontal"
                        Margin="0,8,0,4">

                <Border Background="{StaticResource BadgeGreenBgBrush}"
                        CornerRadius="6" Padding="8,4" Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="TrackerCount" Text="0"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource BadgeGreenBrush}"/>
                        <TextBlock Text=" rastreadores" FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Bottom"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource BadgeAmberBgBrush}"
                        CornerRadius="6" Padding="8,4" Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="AdCount" Text="0"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource BadgeAmberBrush}"/>
                        <TextBlock Text=" anuncios" FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Bottom"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource BadgeRedBgBrush}"
                        CornerRadius="6" Padding="8,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="FingerprintCount" Text="0"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource BadgeRedBrush}"/>
                        <TextBlock Text=" fingerprint" FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Bottom"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Footer hint -->
            <TextBlock Grid.Row="2" Grid.ColumnSpan="2"
                       x:Name="FooterLabel"
                       Text="bloqueados en esta sesión"
                       FontSize="10"
                       Foreground="{StaticResource TextMutedBrush}"
                       Opacity="0.7"/>
        </Grid>
    </Border>
</UserControl>
