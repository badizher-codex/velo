<UserControl x:Class="VELO.UI.Controls.BlockNarrationToast"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="360"
             Visibility="Collapsed"
             Opacity="0"
             AutomationProperties.Name="Block narration">

    <Border Background="#FF111118"
            BorderBrush="#FF8E44AD"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14,12"
            Effect="{StaticResource DropShadowEffect}">

        <StackPanel>
            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="🛡" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="TitleLabel"
                           Text="VELO blocked something"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#FFE0E0F0"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Host + source -->
            <TextBlock x:Name="HostLabel"
                       Text="example.com — Tracker"
                       FontSize="11"
                       Foreground="#FFA0A0B0"
                       Margin="22,0,0,6"
                       TextTrimming="CharacterEllipsis"/>

            <!-- AI-generated narration body -->
            <TextBlock x:Name="BodyLabel"
                       Text=""
                       FontSize="12"
                       Foreground="#FFC8C8DC"
                       TextWrapping="Wrap"
                       Margin="22,0,0,6"
                       MaxHeight="96"
                       TextTrimming="CharacterEllipsis"/>

            <!-- Dismiss -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                <Button x:Name="DismissButton"
                        Content="Cerrar"
                        Click="OnDismissClick"
                        Background="Transparent"
                        Foreground="#FFA0A0B0"
                        BorderBrush="#FF333344"
                        BorderThickness="1"
                        Padding="12,4"
                        Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
