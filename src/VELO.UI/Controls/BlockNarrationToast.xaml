<UserControl x:Class="VELO.UI.Controls.BlockNarrationToast"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="380"
             Visibility="Collapsed"
             Opacity="0"
             AutomationProperties.Name="Block narration">

    <!-- Phase 5.2 re-skin — purple accent (block narration is AI-generated). -->
    <Border Background="{StaticResource SurfaceDarkBrush}"
            BorderBrush="{StaticResource AccentPurpleBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="16,14"
            Effect="{StaticResource DropShadowEffect}">

        <StackPanel>
            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="🛡" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="TitleLabel"
                           Text="VELO blocked something"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Host + source -->
            <TextBlock x:Name="HostLabel"
                       Text="example.com — Tracker"
                       FontSize="11.5"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="22,0,0,8"
                       TextTrimming="CharacterEllipsis"/>

            <!-- AI-generated narration body -->
            <TextBlock x:Name="BodyLabel"
                       Text=""
                       FontSize="12.5"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Opacity="0.85"
                       TextWrapping="Wrap"
                       Margin="22,0,0,8"
                       MaxHeight="110"
                       TextTrimming="CharacterEllipsis"/>

            <!-- Dismiss -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                <Button x:Name="DismissButton"
                        Content="Cerrar"
                        Click="OnDismissClick"
                        Style="{StaticResource GhostButton}"
                        Padding="14,5"
                        FontSize="12"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
