<UserControl x:Class="VELO.UI.Controls.TabSidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:VELO.UI.Converters"
             Width="200"
             x:Name="SidebarRoot">

    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrush"/>
    </UserControl.Resources>

    <Border Background="#FF0D0D1A"
            BorderBrush="#FF2A2A3A"
            BorderThickness="0,0,1,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Top new-tab button -->
                <RowDefinition Height="Auto"/>   <!-- Workspace strip -->
                <RowDefinition Height="*"/>      <!-- Tab list -->
                <RowDefinition Height="Auto"/>   <!-- Bottom actions -->
            </Grid.RowDefinitions>

            <!-- ── Top new-tab button (shortcut so users don't need to scroll) ── -->
            <Border Grid.Row="0"
                    Background="#FF111122"
                    BorderBrush="#FF2A2A3A"
                    BorderThickness="0,0,0,1"
                    Padding="6,6">
                <Button x:Name="TopNewTabBtn"
                        Content="+ Nueva pestaña"
                        FontSize="12"
                        Padding="8,6"
                        HorizontalAlignment="Stretch"
                        Background="Transparent"
                        Foreground="#FF8080A0"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="NewTab_Click"
                        ToolTip="Nueva pestaña (Ctrl+T)"/>
            </Border>

            <!-- ── Workspace strip ──────────────────────────────────────── -->
            <Border x:Name="WorkspaceStripBorder"
                    Grid.Row="1"
                    Background="#FF111122"
                    BorderBrush="#FF2A2A3A"
                    BorderThickness="0,0,0,1"
                    Padding="6,6">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="WorkspaceStrip"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"/>
                </ScrollViewer>
            </Border>

            <!-- ── Collapsed tab list (v2.0.5) ─────────────────────────────
                 Shown only when the sidebar is compacted. Renders 28×28 squares
                 with the first letter of each tab's title, tinted by the tab's
                 container colour (or its accent palette tone). Active tab gets
                 a brighter ring. -->
            <ScrollViewer x:Name="CollapsedTabListScroller"
                          Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="0,4,0,4"
                          Visibility="Collapsed">
                <ItemsControl x:Name="CollapsedTabList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border MinHeight="32"
                                    MinWidth="32"
                                    Margin="6,3"
                                    CornerRadius="6"
                                    BorderThickness="2"
                                    Cursor="Hand"
                                    Background="{Binding SubtleAccentColor, Converter={StaticResource StringToBrush}}"
                                    Tag="{Binding Id}"
                                    MouseLeftButtonDown="Tab_Click"
                                    MouseRightButtonDown="Tab_RightClick"
                                    ToolTip="{Binding Title}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="#FF2A2A3A"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="BorderBrush" Value="#FF00E5FF"/>
                                                <Setter Property="Background" Value="#FF1A1A2E"/>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" Value="#FF7080A0"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Initial}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#FFD0D0E8"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- ── Tab list ─────────────────────────────────────────────── -->
            <ScrollViewer x:Name="TabListScroller"
                          Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="0,4,0,4">
                <ItemsControl x:Name="TabList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Tab row: outer Border carries the per-tab accent tint (local
                                 value so it is never overridden by style triggers); the inner
                                 Border overlays a semi-transparent dark wash for active/hover
                                 states so the tint still bleeds through subtly.
                                 v2.0.5.4 — When the tab is active the outer Border switches to
                                 a 2 px cyan ring on all sides so the active row is unmistakable
                                 in the expanded sidebar (mirrors the collapsed-mode treatment). -->
                            <Border x:Name="TabRow"
                                    Background="{Binding SubtleAccentColor, Converter={StaticResource StringToBrush}}"
                                    MinHeight="38"
                                    Cursor="Hand"
                                    Margin="0,1"
                                    MouseLeftButtonDown="Tab_Click"
                                    MouseMove="Tab_MouseMove"
                                    MouseRightButtonDown="Tab_RightClick"
                                    Tag="{Binding Id}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <!-- Default: 3px container colour stripe on the left -->
                                        <Setter Property="BorderThickness" Value="3,0,0,0"/>
                                        <Setter Property="BorderBrush"
                                                Value="{Binding ContainerColor, Converter={StaticResource StringToBrush}}"/>
                                        <Setter Property="CornerRadius" Value="0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="BorderThickness" Value="2"/>
                                                <Setter Property="BorderBrush" Value="#FF00E5FF"/>
                                                <Setter Property="CornerRadius" Value="4"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <!-- Active / hover overlay — semi-transparent so accent shows through -->
                                <Border>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="Background" Value="#D91A1A2E"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#99141425"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                <Grid Margin="10,6,6,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16"/>  <!-- Favicon -->
                                        <ColumnDefinition Width="*"/>   <!-- Title -->
                                        <ColumnDefinition Width="18"/>  <!-- Close -->
                                    </Grid.ColumnDefinitions>

                                    <!-- Favicon / loading indicator -->
                                    <TextBlock Grid.Column="0"
                                               FontSize="11"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="🌐"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                                        <Setter Property="Text" Value="⏳"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- Title -->
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Title}"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"
                                               Margin="6,0,4,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#FF666688"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Foreground" Value="#FFD0D0E8"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- Close -->
                                    <Button Grid.Column="2"
                                            Content="✕"
                                            FontSize="9"
                                            Padding="2"
                                            Style="{StaticResource IconButton}"
                                            VerticalAlignment="Center"
                                            Foreground="#FF444466"
                                            Tag="{Binding Id}"
                                            Click="CloseTab_Click"/>
                                </Grid>
                                </Border>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- ── Bottom actions ────────────────────────────────────────── -->
            <Border Grid.Row="3"
                    Background="#FF111122"
                    BorderBrush="#FF2A2A3A"
                    BorderThickness="0,1,0,0"
                    Padding="6,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- New tab — content & tooltip updated by ApplyLanguage() -->
                    <Button Grid.Column="0"
                            x:Name="NewTabBtn"
                            Content="+ Nueva pestaña"
                            FontSize="12"
                            Padding="8,6"
                            HorizontalAlignment="Stretch"
                            Background="Transparent"
                            Foreground="#FF555577"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="NewTab_Click"
                            ToolTip="Nueva pestaña (Ctrl+T)"/>

                    <!-- Split view toggle -->
                    <Button Grid.Column="1"
                            x:Name="SplitBtn"
                            Content="⊞"
                            FontSize="14"
                            Style="{StaticResource IconButton}"
                            ToolTip="Vista dividida (Ctrl+\)"
                            Click="Split_Click"/>

                    <!-- Add workspace -->
                    <Button Grid.Column="2"
                            x:Name="AddWorkspaceBtn"
                            Content="＋"
                            FontSize="14"
                            Style="{StaticResource IconButton}"
                            ToolTip="Nuevo workspace"
                            Click="AddWorkspace_Click"/>

                    <!-- Collapse / expand sidebar -->
                    <Button Grid.Column="3"
                            x:Name="CollapseBtn"
                            Content="◀"
                            FontSize="11"
                            Style="{StaticResource IconButton}"
                            ToolTip="Compactar barra lateral"
                            Click="Collapse_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
