<UserControl x:Class="VELO.UI.Controls.TabSidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:VELO.UI.Converters"
             Width="200"
             x:Name="SidebarRoot"
             AllowDrop="True"
             DragEnter="Sidebar_DragEnter"
             DragOver="Sidebar_DragOver"
             Drop="Sidebar_Drop">

    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrush"/>
        <conv:BytesToImageSourceConverter x:Key="BytesToImage"/>
    </UserControl.Resources>

    <Border Background="{StaticResource SurfaceDarkBrush}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="0,0,1,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Top new-tab button -->
                <RowDefinition Height="Auto"/>   <!-- Workspace strip -->
                <RowDefinition Height="*"/>      <!-- Tab list -->
                <RowDefinition Height="Auto"/>   <!-- Bottom actions -->
            </Grid.RowDefinitions>

            <!-- ── Top new-tab button (shortcut so users don't need to scroll) ── -->
            <Border Grid.Row="0"
                    Background="{StaticResource BackgroundDarkestBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="6,6">
                <Button x:Name="TopNewTabBtn"
                        Content="+ Nueva pestaña"
                        FontSize="12"
                        Padding="8,6"
                        HorizontalAlignment="Stretch"
                        Background="Transparent"
                        Foreground="{StaticResource TextMutedBrush}"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="NewTab_Click"
                        ToolTip="Nueva pestaña (Ctrl+T)"/>
            </Border>

            <!-- ── Workspace strip ──────────────────────────────────────── -->
            <Border x:Name="WorkspaceStripBorder"
                    Grid.Row="1"
                    Background="{StaticResource BackgroundDarkestBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="6,6">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="WorkspaceStrip"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"/>
                </ScrollViewer>
            </Border>

            <!-- ── Collapsed tab list (v2.0.5) ─────────────────────────────
                 Shown only when the sidebar is compacted. Renders 28×28 squares
                 with the first letter of each tab's title, tinted by the tab's
                 container colour (or its accent palette tone). Active tab gets
                 a brighter ring. -->
            <ScrollViewer x:Name="CollapsedTabListScroller"
                          Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="0,4,0,4"
                          Visibility="Collapsed">
                <ItemsControl x:Name="CollapsedTabList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border MinHeight="32"
                                    MinWidth="32"
                                    Margin="6,3"
                                    CornerRadius="6"
                                    BorderThickness="2"
                                    Cursor="Hand"
                                    Background="{Binding SubtleAccentColor, Converter={StaticResource StringToBrush}}"
                                    Tag="{Binding Id}"
                                    MouseLeftButtonDown="Tab_Click"
                                    MouseRightButtonDown="Tab_RightClick"
                                    MouseDown="Tab_MiddleClick"
                                    ToolTip="{Binding Title}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentPurpleBrush}"/>
                                                <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}"/>
                                                <!-- v2.4.37 — glow also in collapsed mode. -->
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#7C5CFF"
                                                                          Opacity="0.55"
                                                                          BlurRadius="14"
                                                                          ShadowDepth="0"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource BorderEmphasisBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <!-- v2.4.50 — favicon over the letter initial. Same converter as the
                                     expanded view (v2.4.43); fall back to the letter when the host has
                                     no favicon yet (covers velo://newtab + first-load gap). -->
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Image Source="{Binding FaviconData, Converter={StaticResource BytesToImage}}"
                                           Width="18" Height="18"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <TextBlock FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding Initial}"/>
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FaviconData}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- ── Tab list ─────────────────────────────────────────────── -->
            <ScrollViewer x:Name="TabListScroller"
                          Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="0,4,0,4">
                <ItemsControl x:Name="TabList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Tab row: outer Border carries the per-tab accent tint (local
                                 value so it is never overridden by style triggers); the inner
                                 Border overlays a semi-transparent dark wash for active/hover
                                 states so the tint still bleeds through subtly.
                                 v2.0.5.4 — When the tab is active the outer Border switches to
                                 a 2 px cyan ring on all sides so the active row is unmistakable
                                 in the expanded sidebar (mirrors the collapsed-mode treatment). -->
                            <Border x:Name="TabRow"
                                    Background="{Binding SubtleAccentColor, Converter={StaticResource StringToBrush}}"
                                    MinHeight="38"
                                    Cursor="Hand"
                                    Margin="0,1"
                                    MouseLeftButtonDown="Tab_Click"
                                    MouseMove="Tab_MouseMove"
                                    MouseRightButtonDown="Tab_RightClick"
                                    MouseDown="Tab_MiddleClick"
                                    Tag="{Binding Id}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <!-- Default: 3px container colour stripe on the left -->
                                        <Setter Property="BorderThickness" Value="3,0,0,0"/>
                                        <Setter Property="BorderBrush"
                                                Value="{Binding ContainerColor, Converter={StaticResource StringToBrush}}"/>
                                        <Setter Property="CornerRadius" Value="0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="BorderThickness" Value="2"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentPurpleBrush}"/>
                                                <Setter Property="CornerRadius" Value="6"/>
                                                <!-- v2.4.37 — soft purple glow on the active tab so it
                                                     reads as the focus point, not just a coloured ring. -->
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#7C5CFF"
                                                                          Opacity="0.55"
                                                                          BlurRadius="16"
                                                                          ShadowDepth="0"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <!-- Active / hover overlay — semi-transparent so accent shows through -->
                                <Border>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <!-- Active row: semi-transparent purple wash over the per-tab accent tint. -->
                                                    <Setter Property="Background" Value="#A6261942"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#661F1F2C"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                <Grid Margin="10,6,6,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16"/>  <!-- Favicon -->
                                        <ColumnDefinition Width="*"/>   <!-- Title -->
                                        <ColumnDefinition Width="18"/>  <!-- Close -->
                                    </Grid.ColumnDefinitions>

                                    <!-- Favicon (real, from WebView2) / loading indicator / 🌐 fallback.
                                         v2.4.43: Image binds to TabInfo.FaviconData via BytesToImage converter
                                         (returns Binding.DoNothing on null/empty bytes). The TextBlock under it
                                         shows 🌐 when no favicon is captured yet AND not loading, ⏳ during load. -->
                                    <Grid Grid.Column="0" VerticalAlignment="Center"
                                          Width="14" Height="14">
                                        <Image Source="{Binding FaviconData, Converter={StaticResource BytesToImage}}"
                                               Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <TextBlock FontSize="11"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="🌐"/>
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding FaviconData}" Value="{x:Null}"/>
                                                                <Condition Binding="{Binding IsLoading}" Value="False"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </MultiDataTrigger>
                                                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                                            <Setter Property="Text" Value="⏳"/>
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>

                                    <!-- Title -->
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Title}"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"
                                               Margin="6,0,4,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- Close -->
                                    <Button Grid.Column="2"
                                            Content="✕"
                                            FontSize="9"
                                            Padding="2"
                                            Style="{StaticResource IconButton}"
                                            VerticalAlignment="Center"
                                            Foreground="{StaticResource TextMutedBrush}"
                                            Tag="{Binding Id}"
                                            Click="CloseTab_Click"/>
                                </Grid>
                                </Border>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- ── Bottom actions ────────────────────────────────────────── -->
            <Border Grid.Row="3"
                    Background="{StaticResource BackgroundDarkestBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="6,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- New tab — content & tooltip updated by ApplyLanguage() -->
                    <Button Grid.Column="0"
                            x:Name="NewTabBtn"
                            Content="+ Nueva pestaña"
                            FontSize="12"
                            Padding="8,6"
                            HorizontalAlignment="Stretch"
                            Background="Transparent"
                            Foreground="{StaticResource TextMutedBrush}"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="NewTab_Click"
                            ToolTip="Nueva pestaña (Ctrl+T)"/>

                    <!-- Split view toggle -->
                    <Button Grid.Column="1"
                            x:Name="SplitBtn"
                            Content="⊞"
                            FontSize="14"
                            Style="{StaticResource IconButton}"
                            ToolTip="Vista dividida (Ctrl+\)"
                            Click="Split_Click"/>

                    <!-- Add workspace -->
                    <Button Grid.Column="2"
                            x:Name="AddWorkspaceBtn"
                            Content="＋"
                            FontSize="14"
                            Style="{StaticResource IconButton}"
                            ToolTip="Nuevo workspace"
                            Click="AddWorkspace_Click"/>

                    <!-- Collapse / expand sidebar -->
                    <Button Grid.Column="3"
                            x:Name="CollapseBtn"
                            Content="◀"
                            FontSize="11"
                            Style="{StaticResource IconButton}"
                            ToolTip="Compactar barra lateral"
                            Click="Collapse_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
