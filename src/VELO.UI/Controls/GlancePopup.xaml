<UserControl x:Class="VELO.UI.Controls.GlancePopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Width="420"
             Height="280"
             Visibility="Collapsed">

    <Border Background="#FF0D0D1A"
            BorderBrush="#FF3A3A5A"
            BorderThickness="1"
            CornerRadius="6">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="0"
                              Color="#000000" Opacity="0.75"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>   <!-- Title bar -->
                <RowDefinition Height="*"/>    <!-- WebView -->
            </Grid.RowDefinitions>

            <!-- ── Title bar ──────────────────────────────────────────── -->
            <Border Grid.Row="0"
                    Background="#FF111122"
                    CornerRadius="6,6,0,0"
                    Padding="10,0">
                <Grid>
                    <TextBlock x:Name="PreviewUrl"
                               Text=""
                               FontSize="11"
                               Foreground="#FF555577"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="Glance"
                               FontSize="10"
                               Foreground="#FF333355"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ── Preview WebView2 ───────────────────────────────────── -->
            <wv2:WebView2 x:Name="PreviewWebView"
                          Grid.Row="1"/>
        </Grid>
    </Border>
</UserControl>
